		<form method="post" action="{{ delete }}" enctype="multipart/form-data" id="form-poorder">
			<div class="table-container excel-dark-table">
  <div class="table-responsive">
    <table class="table m-0">
      <thead>
        <tr>
          <th class="text-center" style="width:30px;">
            <input type="checkbox"
              onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" />
          </th>

          <th>SRNO</th>
          <th>OrderId</th>
          <th>Date</th>
          <th>R_Price</th>
          <th>R_Tax</th>
          <th>R_Total</th>
          <th>S_Price</th>
          <th>S_Tax</th>
          <th>S_Total</th>
          <th>CASH</th>
          <th>UPI</th>
          <th>Advance</th>
          <th>Ref</th>
          <th>Discount</th>
          <th>SellerId</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        {% if orders %}
          {% for order in orders %}
          <tr>
            <td class="text-center">
              <input type="checkbox" name="selected[]" value="{{ order.order_id }}">
            </td>

            <td>{{ loop.index }}</td>
            <td>{{ order.order_id }}</td>
            <td>{{ order.date_added }}</td>

            <td>{{ order.r_price }}</td>
            <td>{{ order.r_tax }}</td>
            <td>{{ order.r_total }}</td>

            <td>{{ order.s_price }}</td>
            <td>{{ order.s_tax }}</td>
            <td>{{ order.s_total }}</td>

            <td>{{ order.cash }}</td>
            <td>{{ order.upi }}</td>
            <td>{{ order.advance }}</td>
            <td>{{ order.ref }}</td>
            <td>{{ order.discount }}</td>
            <td>{{ order.seller_id }}</td>

            <td>
              <a href="{{ order.view }}" class="btn btn-xs btn-primary">
                <i class="fa fa-pencil"></i>
              </a>
              <a href="{{ order.invoice }}" class="btn btn-xs btn-info" target="_blank">
                <i class="fa fa-print"></i>
              </a>
            </td>
          </tr>
          {% endfor %}
        {% else %}
          <tr>
            <td colspan="17" class="text-center">No results</td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
</div>

		</form>
