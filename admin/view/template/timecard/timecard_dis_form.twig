  <script type="text/javascript">
    function syncBiometricData() {
    var btn = document.getElementById('btn-sync-biometric');
    var icon = document.getElementById('sync-icon');
    
    // Get dates from your filters if they exist
    var fromDateInput = document.querySelector('input[name="filter_fdate"]');
    var toDateInput = document.querySelector('input[name="filter_tdate"]');
    
    var fromDate = fromDateInput ? fromDateInput.value : '{{ filter_fdate }}';
    var toDate = toDateInput ? toDateInput.value : '{{ filter_tdate }}';
    
    // Confirm before sync
    if (!confirm('Sync biometric data from ' + fromDate + ' to ' + toDate + '?')) {
        return;
    }
    
    // Disable button
    btn.disabled = true;
    btn.style.opacity = '0.6';
    btn.style.cursor = 'not-allowed';
    icon.innerHTML = '⏳';
    
    // Create XMLHttpRequest
    var xhr = new XMLHttpRequest();
    var url = 'index.php?route=timecard/timecard.syncBiometric&user_token={{ user_token }}';
    
    xhr.open('POST', url, true);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    
    xhr.onreadystatechange = function() {
        if (xhr.readyState === 4) {
            // Re-enable button
            btn.disabled = false;
            btn.style.opacity = '1';
            btn.style.cursor = 'pointer';
            icon.innerHTML = '🔄';
            
            if (xhr.status === 200) {
                try {
                    var response = JSON.parse(xhr.responseText);
                    
                    if (response.error) {
                        alert('Error: ' + response.error);
                    } else if (response.success) {
                        alert('Success!\n\n' + response.success + 
                              '\n\nTotal Records: ' + response.total + 
                              '\nNew Records: ' + response.inserted);
                        
                        // Reload page to show updated data
                        window.location.reload();
                    }
                } catch (e) {
                    alert('Error parsing response: ' + e.message);
                    console.error('Response:', xhr.responseText);
                }
            } else {
                alert('HTTP Error: ' + xhr.status + '\n' + xhr.statusText);
            }
        }
    };
    
    // Send request
    var params = 'from_date=' + encodeURIComponent(fromDate) + '&to_date=' + encodeURIComponent(toDate);
    xhr.send(params);
}

// Also add this to handle errors
window.addEventListener('error', function(e) {
    console.error('JavaScript Error:', e.message);
}, true);
    </script>
