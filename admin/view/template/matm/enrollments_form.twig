{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="submit" form="form-product" data-toggle="tooltip" title="{{ button_save }}" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-light"><i class="fa-solid fa-reply"></i></a></div>
      <h1 style="color:white">{{ heading_title }}</h1>
            <ol class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}
            <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid"> {% if error_warning %}
      <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
        <button type="button" class="close" data-dismiss="alert">&times;</button>
      </div>
    {% endif %}
    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title" style="color:white"><i class="fa fa-pencil"></i></h3>
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-product" class="form-horizontal">
          {#<ul class="nav nav-tabs">
            <li class="active"><a href="#tab-data" data-toggle="tab">{{ tab_data }}</a></li>
            <li><a href="#tab-address-def" data-toggle="tab">{{ tab_address_def }}</a></li>
             <li><a href="#tab-address-off" data-toggle="tab">{{ tab_address_off }}</a></li>
            <li><a href="#tab-image" data-toggle="tab">{{ tab_image }}</a></li>
          </ul>#}
          <div class="tab-content">
            <div class="tab-pane active" id="tab-data">
               <div class="row mb-12" style="row-gap: 20px;">
                <div class="col-sm-4">
                <label class="control-label" for="input-customerid" style="color:white">{{ entry_customerid }}</label>
                  <input type="text" name="customerid" value="{{ customerid }}" placeholder="{{ entry_customerid }}" id="input-customerid" class="form-control"/>
                  {% if error_customerid %}
                    <div class="text-danger">{{ error_customerid }}</div>
                  {% endif %}
                  </div>
                    <div class="col-sm-4">
                    <label class=" control-label" for="input-firstname" style="color:white">{{ entry_firstname }}</label>
                  <input type="text" name="firstname" value="{{ firstname }}" placeholder="{{ entry_firstname }}" id="input-firstname" class="form-control"/>
                  {% if error_firstname %}
                    <div class="text-danger">{{ error_firstname }}</div>
                  {% endif %}
                  </div>
              <div class="col-sm-4">
                <label class=" control-label" for="input-middlename"style="color:white">{{ entry_middlename }}</label>
                  <input type="text" name="middlename" value="{{ middlename }}" placeholder="{{ entry_middlename }}" id="input-middlename" class="form-control"/>
                  {% if error_middlename %}
                    <div class="text-danger">{{ error_middlename }}</div>
                  {% endif %}
                  </div>
              <div class="col-sm-4">
                <label class="control-label" for="input-lastname" style="color:white">{{ entry_lastname }}</label>
                  <input type="text" name="lastname" value="{{ lastname }}" placeholder="{{ entry_lastname }}" id="input-lastname" class="form-control"/>
                  {% if error_lastname %}
                    <div class="text-danger">{{ error_lastname }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="control-label" for="input-company_name" style="color:white">{{ entry_company_name }}</label>
                  <input type="text" readonly name="company_name" value="{{ company_name }}" placeholder="{{ entry_company_name }}" id="input-company_name" class="form-control"/>
              </div>
              <div class="col-sm-4">
                <label class="control-label" for="input-mobilenumber"style="color:white">{{ entry_mobilenumber }}</label>
                  <input type="text" name="mobilenumber" value="{{ mobilenumber }}" placeholder="{{ entry_mobilenumber }}" id="input-mobilenumber" class="form-control"/>
                  {% if error_mobilenumber %}
                    <div class="text-danger">{{ error_mobilenumber }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="control-label" for="input-matmid"style="color:white">{{ entry_matmid }}</label>
                  <input type="text" name="matmid" value="{{ matmid }}" placeholder="{{ entry_matmid }}" id="input-matmid" class="form-control"/>
              </div>
               <div class="col-sm-4">
                <label class=" control-label" for="input-email"style="color:white">{{ entry_email }}</label>
                  <input type="email" name="email" value="{{ email }}" placeholder="{{ entry_email }}" id="input-email" class="form-control"/>
                  {% if error_email %}
                    <div class="text-danger">{{ error_email }}</div>
                  {% endif %}
              </div> 
              <div class="col-sm-4">
                <label class="control-label" for="input-dob"style="color:white">{{ entry_dob }}</label>
                  <input type="date" name="dob" value="{{ dob }}" placeholder="{{ entry_dob }}" id="input-dob" class="form-control"/>
                  {% if error_dob %}
                    <div class="text-dob">{{ error_dob }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="control-label" for="input-created"style="color:white">{{ entry_created }}</label>
                  <input type="text" readonly name="created" value="{{ created }}" placeholder="{{ entry_created }}" id="input-created" class="form-control"/>
              </div>
              <div class="col-sm-4">
                <label class="control-label" for="input-status"style="color:white">{{ entry_status }}</label>
                  <select name="status" id="input-status" class="form-control">


                    {% if status == '1' %}


                      <option value="1" selected="selected">{{ text_pending }}</option>
                      <option value="2">{{ text_rejected }}</option>
                      <option value="3">{{ text_hold }}</option>
                      <option value="4">{{ text_approved }}</option>


                    {% elseif status == '2' %}


                      <option value="1">{{ text_pending }}</option>
                      <option value="2" selected="selected">{{ text_rejected }}</option>
                      <option value="3">{{ text_hold }}</option>
                      <option value="4">{{ text_approved }}</option>
                    {% elseif status == '3' %}


                      <option value="1">{{ text_pending }}</option>
                      <option value="2">{{ text_rejected }}</option>
                      <option value="3" selected="selected">{{ text_hold }}</option>
                      <option value="4">{{ text_approved }}</option>
                    {% elseif status == '4' %}


                      <option value="1">{{ text_pending }}</option>
                      <option value="2">{{ text_rejected }}</option>
                      <option value="3">{{ text_hold }}</option>
                      <option value="4" selected="selected">{{ text_approved }}</option>
                    {% else %}


                      <option value="1">{{ text_pending }}</option>
                      <option value="2">{{ text_rejected }}</option>
                      <option value="3">{{ text_hold }}</option>
                      <option value="4">{{ text_approved }}</option>
                    {% endif %}


                  </select>
              </div>
              <div class="col-sm-4">
                <label class=" control-label" for="input-kyc"style="color:white">{{ entry_kyc }}</label>
                  <select name="kyc" id="input-kyc" class="form-control">


                    {% if kyc == '1' %}


                      <option value="1" selected="selected">{{ text_completed }}</option>
                      <option value="0">{{ text_pending }}</option>


                    {% else %}


                      <option value="1">{{ text_completed }}</option>
                      <option value="0" selected="selected">{{ text_pending }}</option>


                    {% endif %}


                  </select>
              </div>
              <div class="col-sm-4">
                <label class=" control-label" for="input-city"style="color:white">{{ entry_city }}</label>
                  <input type="text" name="city" value="{{ city }}" placeholder="{{ entry_city }}" id="input-city" class="form-control"/>
                  {% if error_city %}
                    <div class="text-danger">{{ error_city }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="col-sm-2 control-label" for="input-state"style="color:white">{{ entry_state }}</label>
                  <input type="text" name="state" value="{{ state }}" placeholder="{{ entry_state }}" id="input-state" class="form-control"/>
                  {% if error_state %}
                    <div class="text-danger">{{ error_state }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="col-sm-2 control-label" for="input-pincode"style="color:white">{{ entry_pincode }}</label>
                  <input type="text" name="pincode" value="{{ pincode }}" placeholder="{{ entry_pincode }}" id="input-pincode" class="form-control"/>
                  {% if error_pincode %}
                    <div class="text-danger">{{ error_pincode }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="col-sm-2 control-label" for="input-district"style="color:white">{{ entry_district }}</label>
                  <input type="text" name="district" value="{{ district }}" placeholder="{{ entry_district }}" id="input-district" class="form-control"/>
                  {% if error_district %}
                    <div class="text-danger">{{ error_district }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="col-sm-2 control-label" for="input-area"style="color:white">{{ entry_area }}</label>
                  <input type="text" name="area" value="{{ area }}" placeholder="{{ entry_area }}" id="input-area" class="form-control"/>
                  {% if error_area %}
                    <div class="text-danger">{{ error_area }}</div>
                  {% endif %}
              </div>
               </div>
               <div class="row mb-12" style="row-gap: 20px;">
              <div class="col-sm-6">
                <label class="col-sm-2 control-label" for="input-address"style="color:white">{{ entry_address }}</label>
                  <textarea name="address" placeholder="{{ entry_address}}" id="input-address" class="form-control"/>{{ address }}</textarea>
                  {% if error_address %}
                    <div class="text-danger">{{ error_address }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-6">
                <label class="control-label" for="input-comments"style="color:white">{{ entry_comments }}</label>
                  <textarea name="comments" placeholder="{{ entry_comments}}" id="input-comments" class="form-control"/>{{ comments }}</textarea>
              </div>
           </div>
            {#<div class="tab-pane" id="tab-address-def">
              <div class="row mb-12" style="row-gap: 20px;">
              
            </div>#}
            {#<div class="tab-pane" id="tab-address-off">
            <div class="row mb-12" style="row-gap: 20px;">
              <div class="col-sm-4">
                <label class="col-sm-2 control-label" for="input-city"style="color:white">{{ entry_city }}</label>
                  <input type="text" name="off_city" value="{{ off_city }}" placeholder="{{ entry_city }}" id="input-city" class="form-control"/>
                  {% if error_off_city %}
                    <div class="text-danger">{{ error_off_city }}</div>
                  {% endif %}
              </div>
              <div class="col-sm-4">
                <label class="col-sm-2 control-label" for="input-state"style="color:white">{{ entry_state }}</label>
