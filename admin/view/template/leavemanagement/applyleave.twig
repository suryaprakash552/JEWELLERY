<!-- JavaScript -->
<script>
document.addEventListener("DOMContentLoaded", function() {
  // Chevron rotation for collapsible form
  var header = document.querySelector('[data-bs-target="#new-leave-request-form"]');
  var icon = header.querySelector('.rotate-icon');
  var collapse = document.getElementById('new-leave-request-form');

  if (collapse) {
    collapse.addEventListener('hide.bs.collapse', function () {
      icon.classList.remove('fa-chevron-up');
      icon.classList.add('fa-chevron-down');
    });

    collapse.addEventListener('show.bs.collapse', function () {
      icon.classList.remove('fa-chevron-down');
      icon.classList.add('fa-chevron-up');
    });
  }

  // AJAX for calculating working days and showing leave balance
  const startDateInput = document.getElementById('input-start-date');
  const endDateInput = document.getElementById('input-end-date');
  const leaveTypeInput = document.getElementById('input-leave-type');
  const totalDaysInput = document.getElementById('input-total-days');
  const leaveBalanceInfo = document.getElementById('leave-balance-info');
  const availableDaysSpan = document.getElementById('available-days');

  function calculateDays() {
    const startDate = startDateInput.value;
    const endDate = endDateInput.value;
    const leaveType = leaveTypeInput.value;

    if (startDate && endDate) {
      // Calculate working days via AJAX
      fetch('{{ action }}/calculateDays', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
        },
        body: new URLSearchParams({
          start_date: startDate,
          end_date: endDate
        })
      })
      .then(response => response.json())
      .then(data => {
        if (data.success) {
          totalDaysInput.value = data.working_days;
          
          // Show leave balance for selected type
          if (leaveType) {
            updateLeaveBalance(leaveType, data.working_days);
          }
        } else {
          totalDaysInput.value = '';
          console.error('Error calculating days:', data.error);
        }
      })
      .catch(error => {
        console.error('AJAX error:', error);
        totalDaysInput.value = '';
      });
    }
  }

  function updateLeaveBalance(leaveType, requestedDays) {
    // Get balance from the leave balance section
    const balanceElement = document.querySelector(`[data-leave-type="${leaveType}"]`);
    if (balanceElement) {
      const balanceText = balanceElement.querySelector('small').textContent;
      const remainingMatch = balanceText.match(/Remaining:\s*(\d+)/);
      
      if (remainingMatch) {
        const remaining = parseInt(remainingMatch[1]);
        availableDaysSpan.textContent = remaining;
        
        // Show/hide the balance info
        leaveBalanceInfo.classList.remove('d-none');
        
        // Change alert class based on availability
        leaveBalanceInfo.className = 'alert d-block';
        if (requestedDays > remaining) {
          leaveBalanceInfo.classList.add('alert-danger');
          leaveBalanceInfo.innerHTML = `<small><strong>Warning:</strong> Requested ${requestedDays} days exceeds available ${remaining} days!</small>`;
        } else {
          leaveBalanceInfo.classList.add('alert-info');
          leaveBalanceInfo.innerHTML = `<small><strong>Available Balance:</strong> ${remaining} days</small>`;
        }
      }
    }
  }

  // Event listeners
  if (startDateInput && endDateInput) {
    startDateInput.addEventListener('change', calculateDays);
    endDateInput.addEventListener('change', calculateDays);
  }
  
  if (leaveTypeInput && totalDaysInput) {
    leaveTypeInput.addEventListener('change', function() {
      if (totalDaysInput.value && this.value) {
        updateLeaveBalance(this.value, parseInt(totalDaysInput.value));
      }
    });
  }
});

// Function to change rows per page
function changeLimit(limit) {
  const url = new URL(window.location.href);
  url.searchParams.set('limit', limit);
  url.searchParams.set('page', 1); // Reset to first page
  window.location.href = url.toString();
}
</script>

