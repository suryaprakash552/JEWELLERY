// Sale Price Change
$(document).on('change keyup blur', '#cart input[name$="[sale_price]"]', function() {
    var name = $(this).attr('name');
    var match = name ? name.match(/product\[(\d+)\]\[sale_price\]/) : null;
    if (!match) return;
    
    var row = match[1];
    var sale_price = $(this).val();
    var discount = $('input[name="product[' + row + '][discount]"]').val();
    
    console.log('=== Sale Price Changed ===');
    var newPrice = calculatePriceFromDiscount(sale_price, discount);
    
    $('input[name="product[' + row + '][price]"]').val(newPrice);
    updateRowTotal(row);
    saveAndRefresh();
});

// Discount Change
$(document).on('change keyup blur', '#cart input[name$="[discount]"]', function() {
    var name = $(this).attr('name');
    var match = name ? name.match(/product\[(\d+)\]\[discount\]/) : null;
    if (!match) return;
    
    var row = match[1];
    var discount = $(this).val();
    var sale_price = $('input[name="product[' + row + '][sale_price]"]').val();
    
    console.log('=== Discount Changed ===');
    var newPrice = calculatePriceFromDiscount(sale_price, discount);
    
    $('input[name="product[' + row + '][price]"]').val(newPrice);
    updateRowTotal(row);
    saveAndRefresh();
});

// Price Change (back-calculate discount)
$(document).on('change keyup blur', '#cart input[name$="[price]"]', function() {
    var name = $(this).attr('name');
    var match = name ? name.match(/product\[(\d+)\]\[price\]/) : null;
    if (!match) return;
    
    var row = match[1];
    var price = $(this).val();
    var sale_price = $('input[name="product[' + row + '][sale_price]"]').val();
    
    console.log('=== Price Changed ===');
    var newDiscount = calculateDiscountFromPrice(sale_price, price);
    
    $('input[name="product[' + row + '][discount]"]').val(newDiscount);
    updateRowTotal(row);
    saveAndRefresh();
});

// Quantity Change
$(document).on('change keyup blur', '#cart input[name$="[quantity]"]', function() {
    var name = $(this).attr('name');
    var match = name ? name.match(/product\[(\d+)\]\[quantity\]/) : null;
    if (!match) return;
    
    var row = match[1];
    console.log('=== Quantity Changed ===');
    updateRowTotal(row);
    saveAndRefresh();
});

// Refresh Buttons (local recalculation only)
$(document).on('click', '#cart .btn-refresh-price, #cart .btn-refresh-sale', function(e) {
    e.preventDefault();
    e.stopPropagation();
    
    var row = $(this).data('row');
    console.log('=== Refresh Button Clicked for Row ' + row + ' ===');
    
    if (row !== undefined && row !== null) {
        // Get existing values
        var sale_price = parseFloat($('input[name="product[' + row + '][sale_price]"]').val()) || 0;
        var discount   = parseFloat($('input[name="product[' + row + '][discount]"]').val()) || 0;
        var current_price = parseFloat($('input[name="product[' + row + '][price]"]').val()) || 0;

        // Optionally recalculate price if discount logic applies
        var newPrice = calculatePriceFromDiscount(sale_price, discount);

        // If you want to simply refresh same price, keep current_price
        if (isNaN(newPrice) || newPrice === 0) {
            newPrice = current_price;
        }

        // Update price field with new or same value
        $('input[name="product[' + row + '][price]"]').val(newPrice.toFixed(2));

        // Recalculate total for that row
        if (typeof updateRowTotal === 'function') {
            updateRowTotal(row);
        }

        // Instantly refresh subtotal/total UI if available
        if (typeof recalcTotalsUI === 'function') {
            recalcTotalsUI();
        }

        // Remove this → we don’t want server call
        // setTimeout(function() { saveAndRefresh(); }, 100);

        console.log('Row ' + row + ' refreshed locally with price: ' + newPrice);
    }
});


