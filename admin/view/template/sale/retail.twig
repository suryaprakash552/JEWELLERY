function openCustomerHistory(phone) {

    const tbody = document.getElementById('customer-history-data');
    tbody.innerHTML = '<tr><td colspan="8" class="text-center">Loading...</td></tr>';

    fetch('index.php?route=sale/retail.getCustomerOrderHistory'
        + '&user_token=' + USER_TOKEN
        + '&phone=' + phone)
    .then(res => res.json())
    .then(data => {

        if (!data.status || !data.rows.length) {
            tbody.innerHTML = '<tr><td colspan="9" class="text-center">No orders found</td></tr>';
            return;
        }

        let html = '';
        data.rows.forEach((row, index) => {
            html += '<tr>' +
                '<td>' + (index + 1) + '</td>' +
                '<td>' + row.date + '</td>' +
                '<td>' + row.order_id + '</td>' +
                '<td>' + row.no_products + '</td>' +
                '<td>' + row.s_total + '</td>' +
                '<td>' + row.cash + '</td>' +
                '<td>' + row.upi + '</td>' +
                '<td>' + (row.advance ?? '0.00') + '</td>' +
                '<td>' + row.due + '</td>' +
                '<td>' + row.coupon + '</td>' +
            '</tr>';
        });

        tbody.innerHTML = html;
    });

    new bootstrap.Modal(document.getElementById('customerHistoryModal')).show();
}


function loadTabData(tabName, page) {
    if (!page) page = currentPage[tabName] || 1;
    currentPage[tabName] = page;

    const endpoints = {
        salesprice:   'sale/retail.getSalesPriceData',
        salesbyorder: 'sale/retail.getSalesByOrderData',
        salesbyproduct:'sale/retail.getSalesByProductData',
        salesbynumber:'sale/retail.getSalesByNumberData',
        salesbyseller:'sale/retail.getSalesBySellerData',
        salesbytotal: 'sale/retail.getSalesByTotalData',
        salesbycoupon: 'sale/retail.getSalesByCouponData'
    };

    let url = 'index.php?route=' + endpoints[tabName] + '&user_token=' + USER_TOKEN + '&page=' + page;

    if (tabName === 'salesprice') {
    const dateAdded = document.querySelector('[name="filter_date_added"]')?.value || '';
    const dateModified = document.querySelector('[name="filter_date_modified"]')?.value || '';

    if (dateAdded) url += '&filter_date_added=' + encodeURIComponent(dateAdded);
    if (dateModified) url += '&filter_date_modified=' + encodeURIComponent(dateModified);
}

if (tabName === 'salesbytotal') {
    const from = document.getElementById('total_from_date')?.value || '';
    const to   = document.getElementById('total_to_date')?.value || '';

    if (from) url += '&filter_date_added=' + encodeURIComponent(from);
    if (to)   url += '&filter_date_modified=' + encodeURIComponent(to);
}
if (tabName === 'salesbyorder') {
    const from = document.querySelector('#tab-salesbyorder [name="filter_date_from"]')?.value || '';
    const to   = document.querySelector('#tab-salesbyorder [name="filter_date_to"]')?.value || '';

    if (from) url += '&filter_date_from=' + encodeURIComponent(from);
    if (to)   url += '&filter_date_to=' + encodeURIComponent(to);
}
if (tabName === 'salesbyseller') {

    const seller_id   = document.querySelector('[name="filter_seller_id"]').value;
    const seller_name = document.querySelector('[name="filter_seller_name"]').value;
    const from        = document.querySelector('[name="filter_date_from_seller"]').value;
    const to          = document.querySelector('[name="filter_date_to_seller"]').value;

    if (seller_id)   url += '&filter_seller_id=' + encodeURIComponent(seller_id);
    if (seller_name) url += '&filter_seller_name=' + encodeURIComponent(seller_name);
    if (from)        url += '&filter_date_from_seller=' + encodeURIComponent(from);
    if (to)          url += '&filter_date_to_seller=' + encodeURIComponent(to);
}
if (tabName === 'salesbycoupon') {

    const from  = document.querySelector('[name="filter_coupon_from"]').value;
    const to    = document.querySelector('[name="filter_coupon_to"]').value;
    const phone = document.querySelector('[name="filter_coupon_phone"]').value;
    const name  = document.querySelector('[name="filter_coupon_name"]').value;

    if (from)  url += '&filter_coupon_from=' + encodeURIComponent(from);
    if (to)    url += '&filter_coupon_to=' + encodeURIComponent(to);
    if (phone) url += '&filter_coupon_phone=' + encodeURIComponent(phone);
    if (name)  url += '&filter_coupon_name=' + encodeURIComponent(name);
}

if (tabName === 'salesbyproduct') {
    const from = document.querySelector('#tab-salesbyproduct [name="filter_date_from"]')?.value || '';
    const to   = document.querySelector('#tab-salesbyproduct [name="filter_date_to"]')?.value || '';

    if (from) url += '&filter_date_from=' + from;
    if (to)   url += '&filter_date_to=' + to;
}

// ðŸ”¥ FILTER â€“ Sales by Number
if (tabName === 'salesbynumber') {
    const phoneInput = document.querySelector('#tab-salesbynumber input[name="filter_phone"]');
    const nameInput  = document.querySelector('#tab-salesbynumber input[name="filter_name"]');

    if (phoneInput && phoneInput.value.trim() !== '') {
        url += '&filter_phone=' + encodeURIComponent(phoneInput.value.trim());
    }

    if (nameInput && nameInput.value.trim() !== '') {
        url += '&filter_name=' + encodeURIComponent(nameInput.value.trim());
    }
}
    fetch(url)
        .then(response => response.json())
        .then(data => {
            if (data.status) {
                renderTableData(tabName, data.rows);
                renderPagination(tabName, data.total, data.page || page, data.limit || 20);
                if (tabName === 'salesbytotal') {
                window.SALES_BY_TOTAL_DATA = data.rows || [];
                window.SALES_BY_TOTAL_LOADED = true;
            }
            } else {
                const tbody = document.getElementById(tabName + '-data');
                if (tbody) {
                    tbody.innerHTML = '<tr><td colspan="20" class="text-center">Error: ' + (data.error || 'Unknown error') + '</td></tr>';
                }
            }
        })
        .catch(error => {
            const tbody = document.getElementById(tabName + '-data');
            if (tbody) {
                tbody.innerHTML = '<tr><td colspan="20" class="text-center">Error loading data: ' + error.message + '</td></tr>';
            }
        });
}

