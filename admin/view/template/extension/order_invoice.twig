{% if received %}
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <button type="button" onclick="window.print();" class="btn btn-info">
          <i class="fa fa-print"></i> Print
        </button>
        <a href="index.php?route=extension/me_purchase_order&user_token={{ user_token }}" class="btn btn-default">
          <i class="fa fa-reply"></i> Back to List
        </a>
      </div>
      <h1>{{ heading_title }} - View Order</h1>
    </div>
  </div>
  <div class="container-fluid">
{% endif %}

<style>
@media print {
  .no-print, .page-header, .float-end {
    display: none !important;
  }
  body {
    background: white;
  }
}

.invoice-box {
  max-width: 1000px;
  margin: auto;
  padding: 30px;
  border: 1px solid #eee;
  box-shadow: 0 0 10px rgba(0, 0, 0, .15);
  font-size: 16px;
  line-height: 24px;
  font-family: 'Helvetica Neue', 'Helvetica', Helvetica, Arial, sans-serif;
  color: #555;
  background: white;
}

.invoice-box table {
  width: 100%;
  line-height: inherit;
  text-align: left;
}

.invoice-box table td {
  padding: 5px;
  vertical-align: top;
}

.invoice-box table tr.top table td {
  padding-bottom: 20px;
}

.invoice-box table tr.information table td {
  padding-bottom: 40px;
}

.invoice-box table tr.heading td {
  background: #eee;
  border-bottom: 1px solid #ddd;
  font-weight: bold;
}

.invoice-box table tr.details td {
  padding-bottom: 20px;
}

.invoice-box table tr.item td {
  border-bottom: 1px solid #eee;
}

.invoice-box table tr.item.last td {
  border-bottom: none;
}

.invoice-box table tr.total td:nth-child(2) {
  border-top: 2px solid #eee;
  font-weight: bold;
}

.status-badge {
  display: inline-block;
  padding: 5px 15px;
  border-radius: 3px;
  font-weight: bold;
}

.status-received {
  background-color: #5cb85c;
  color: white;
}

.status-pending {
  background-color: #f0ad4e;
  color: white;
}
</style>

{% for order in orders %}
<div class="invoice-box">
  <table cellpadding="0" cellspacing="0">
    <tr class="top">
      <td colspan="4">
        <table>
          <tr>
            <td class="title">
              {% if logo %}
              <img src="{{ logo }}" style="width:100%; max-width:200px;">
              {% else %}
              <h2>{{ order.store_name }}</h2>
              {% endif %}
            </td>
            <td style="text-align: right;">
              <strong>Purchase Order #{{ order.po_number }}</strong><br>
              Created: {{ order.date_added }}<br>
              Delivery Date: {{ order.delivery_date }}<br>
              <span class="status-badge status-{{ order.status|lower }}">{{ order.status }}</span>
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <tr class="information">
      <td colspan="2">
        <table>
          <tr>
            <td>
              <strong>{{ text_buyer }}</strong><br>
              {{ order.buyer_company }}<br>
              {{ order.buyer_address }}<br>
              {{ order.buyer_zip_code }}<br>
              Tel: {{ order.buyer_tel }}<br>
              Contact: {{ order.buyer_contact }}<br>
              Email: {{ order.buyer_email }}
            </td>
            <td style="text-align: right;">
              <strong>{{ text_supplier }}</strong><br>
              {{ order.supplier_company }}<br>
              {{ order.supplier_address }}<br>
              {{ order.supplier_zip_code }}<br>
              Tel: {{ order.supplier_tel }}<br>
              Contact: {{ order.supplier_contact }}<br>
              Email: {{ order.supplier_email }}
            </td>
          </tr>
        </table>
      </td>
    </tr>

    <tr class="details">
      <td colspan="2">
        <strong>{{ entry_shipping_method }}:</strong> {{ order.shipping_method }}<br>
        <strong>{{ entry_payment_method }}:</strong> {{ order.payment_method }}<br>
        {% if order.shipping_term %}<strong>{{ entry_shipping_term }}:</strong> {{ order.shipping_term }}<br>{% endif %}
        {% if order.eta %}<strong>{{ entry_eta }}:</strong> {{ order.eta }}<br>{% endif %}
        {% if order.pl_no %}<strong>{{ entry_pl_no }}:</strong> {{ order.pl_no }}{% endif %}
      </td>
    </tr>

    <tr class="heading">
      <td style="width: 5%;">#</td>
      <td style="width: 40%;">{{ entry_product }}</td>
      <td style="width: 15%; text-align: center;">{{ entry_quantity }}</td>
      <td style="width: 20%; text-align: right;">Price</td>
      <td style="width: 20%; text-align: right;">Total</td>
    </tr>

    {% for product in order.product %}
    <tr class="item">
      <td>{{ product.serial_no }}</td>
      <td>
        <strong>{{ product.name }}</strong><br>
        {% if product.model %}Model: {{ product.model }}<br>{% endif %}
        {% if product.sku %}SKU: {{ product.sku }}<br>{% endif %}
        {% if product.option %}
          {% for option in product.option %}
            <small>{{ option.name }}: {{ option.value }}</small><br>
          {% endfor %}
        {% endif %}
        {% if product.comments %}
          <div style="margin-top: 5px; padding: 5px; background: #f9f9f9; border-left: 3px solid #007bff;">
            {% for comment in product.comments %}
              <small><strong>{{ comment.date_added }}:</strong> {{ comment.comment }}</small><br>
            {% endfor %}
          </div>
        {% endif %}
      </td>
      <td style="text-align: center;">{{ product.quantity }}</td>
      <td style="text-align: right;">{{ product.price }}</td>
      <td style="text-align: right;">{{ product.total }}</td>
    </tr>
    {% endfor %}

    <tr class="total">
      <td colspan="4" style="text-align: right;"></td>
      <td style="text-align: right;"></td>
    </tr>

    {% for total in order.total %}
    <tr class="total">
      <td colspan="4" style="text-align: right;"><strong>{{ total.title }}:</strong></td>
      <td style="text-align: right;"><strong>{{ total.text }}</strong></td>
    </tr>
    {% endfor %}
  </table>

  <div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #eee;">
    <table width="100%">
      <tr>
        <td width="50%">
          <strong>Prepared By:</strong><br>
          {{ order.username }}<br>
          {{ order.useremail }}
        </td>
        <td width="50%" style="text-align: right;">
          <strong>Store:</strong><br>
          {{ order.store_name }}<br>
          {{ order.store_telephone }}
        </td>
      </tr>
    </table>
  </div>
</div>
{% endfor %}

{% if received %}
  </div>
</div>
{{ footer }}
{% endif %}

{% if print %}
<script type="text/javascript">
window.onload = function() {
  window.print();
}
</script>
{% endif %}