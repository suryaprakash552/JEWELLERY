    });

// Handle Payment Method Selection
$('#paymentMethodSelect').on('change', function() {
    const method = $(this).val();

    // Hide all method detail sections first
    $('.payment-method-details').hide();

    if (method) {
        $('#paymentDetailsSection').show();

        switch (method) {
            case 'cash':
                $('#cashDetails').show();
                break;

            case 'Cheque':
                $('#chequeDetails').show();
                $('#chequeDate').val(new Date().toISOString().split('T')[0]);
                break;

            case 'netbanking':
                $('#netbankingDetails').show();
                $('#transferDate').val(new Date().toISOString().split('T')[0]);
                break;

            case 'autopay':
                $('#autopayDetails').show();
                break;
        }
    } else {
        $('#paymentDetailsSection').hide();
    }
 });
 
// Confirm Payment Submission
$('#btnConfirmPayment').on('click', function() {
    const payrollId = $('#paymentPayrollId').val();
    const paymentMethod = $('#paymentMethodSelect').val();

    if (!payrollId) {
        alert('Payroll ID is missing');
        return;
    }

    if (!paymentMethod) {
        alert('Please select a payment method');
        return;
    }

    let isValid = true;
    let paymentDetails = {};

    // Validate based on payment method
    switch (paymentMethod) {
        case 'cash':
            paymentDetails = {
                receipt_no: $('#cashReceiptNo').val().trim(),
                notes: $('#cashNotes').val().trim()
            };
            break;

        case 'Cheque':
            const chequeNumber = $('#chequeNumber').val().trim();
            const chequeDate = $('#chequeDate').val();
            const bankName = $('#chequeBankName').val().trim();
            if (!chequeNumber || !chequeDate || !bankName) {
                alert('Please fill all required Cheque details');
                isValid = false;
            } else {
                paymentDetails = {
                    cheque_number: chequeNumber,
                    cheque_date: chequeDate,
                    bank_name: bankName,
                    branch: $('#chequeBranch').val().trim(),
                    notes: $('#chequeNotes').val().trim()
                };
            }
            break;

        case 'netbanking':
            const transactionId = $('#transactionId').val().trim();
            if (!transactionId) {
                alert('Please enter transaction ID');
                isValid = false;
            } else {
                paymentDetails = {
                    transaction_id: transactionId,
                    transfer_mode: $('#transferMode').val(),
                    transfer_date: $('#transferDate').val(),
                    from_account: $('#fromAccount').val().trim(),
                    notes: $('#netbankingNotes').val().trim()
                };
            }
            break;

        case 'autopay':
            if (!$('#autopayConfirm').is(':checked')) {
                alert('Please confirm automatic payment');
                isValid = false;
            } else {
                paymentDetails = {
                    batch_reference: $('#autopayReference').val().trim(),
                    notes: $('#autopayNotes').val().trim()
                };
            }
            break;
    }

    if (!isValid) return;

    // Confirm
    if (!confirm('Are you sure you want to process this payment?')) return;

    // Disable button
    $('#btnConfirmPayment').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Processing...');

    // Prepare data
    const postData = {
        payroll_id: payrollId,
        payment_method: paymentMethod,
        payment_reference: JSON.stringify(paymentDetails)
    };

    // Send AJAX request
    $.ajax({
        url: 'index.php?route=payroll/payroll.pay&user_token={{ user_token }}',
        type: 'POST',
        dataType: 'json',
        data: postData,
        success: function(response) {
            $('#btnConfirmPayment').prop('disabled', false).html('<i class="fa-solid fa-check-circle"></i> Confirm Payment');

            if (response.success) {
                alert('Success: ' + response.success);
                
                // Remove blur effects before closing modals
                $('#payrollModal .modal-dialog').css({
                    'filter': 'none',
                    'opacity': '1',
                    'pointer-events': 'auto'
                });
                $('#customBackdrop').remove();
                
                $('#paymentProcessModal').modal('hide');
                $('#payrollModal').modal('hide');
                
                // Refresh filtered data
                filterEmployees();
            } else {
                alert('Error: ' + (response.error || 'Payment processing failed'));
            }
        },
        error: function(xhr) {
            $('#btnConfirmPayment').prop('disabled', false).html('<i class="fa-solid fa-check-circle"></i> Confirm Payment');
            alert('Error: ' + xhr.responseText);
        }
    });
 });
 
 $(document).ready(function() {
    // Generate month options
    var months = ['January', 'February', 'March', 'April', 'May', 'June', 
                  'July', 'August', 'September', 'October', 'November', 'December'];
    months.forEach(function(month, index) {
        var val = ('0' + (index + 1)).slice(-2);
        $('#filterMonth').append('<option value="' + val + '">' + month + '</option>');
    });
    
    // Generate year options
    var currentYear = new Date().getFullYear();
    for (var i = currentYear; i >= currentYear - 5; i--) {
        $('#filterYear').append('<option value="' + i + '">' + i + '</option>');
    }
    
    // Set default values
    var currentMonth = ('0' + (new Date().getMonth() + 1)).slice(-2);
    $('#filterMonth').val(currentMonth);
    $('#filterYear').val(currentYear);
    
    // Trigger filter on change
    $('#filterMonth, #filterYear').on('change', filterEmployees);
    $('#employee-search').on('keyup', filterEmployees);
    $('#searchBtn').on('click', filterEmployees);
 });
 
 // Filter employees with AJAX
function filterEmployees() {
    var month = $('#filterMonth').val();
    var year = $('#filterYear').val();
    var search = $('#employee-search').val().toLowerCase();
    
    // Use current date if nothing selected
    if (!month) month = ('0' + (new Date().getMonth() + 1)).slice(-2);
    if (!year) year = new Date().getFullYear();
    
    console.log('Filtering with:', {month: month, year: year, search: search});
    
    // Show loading
    $('#loading-text').text('Loading payroll records...');
    $('#loadingModal').modal('show');
    
    // Fetch filtered data from server
    $.ajax({
        url: 'index.php?route=payroll/payroll.filter&user_token={{ user_token }}',
        type: 'POST',
        dataType: 'json',
        data: {
            year: year,
            month: month,
            search: search
        },
        success: function(response) {
            console.log('Response received:', response);
            $('#loadingModal').modal('hide');
            
            if (response.success) {
                // Clear existing table
                $('#employee-table tbody').empty();
                
                if (response.payrollDetails && response.payrollDetails.length > 0) {
                    // Populate table with filtered data
                    var html = '';
                    $.each(response.payrollDetails, function(index, detail) {
                        var payroll = detail.payroll;
                        var statusBadge = '';
                        
                        if (payroll.status === 'Pending') {
                            statusBadge = '<span class="badge bg-warning">Pending</span>';
                        } else if (payroll.status === 'Paid') {
                            statusBadge = '<span class="badge bg-success">Paid</span>';
                        } else if (payroll.status === 'Released') {
                            statusBadge = '<span class="badge bg-info">Released</span>';
                        } else {
                            statusBadge = '<span class="badge bg-secondary">' + payroll.status + '</span>';
                        }
                        
                        html += '<tr>';
                        html += '<td>';
                        html += '<strong>' + detail.name + '</strong><br>';
                        html += '<small class="text-muted">Emp_ID: ' + detail.user_id + '</small><br>';
                        html += '<small class="text-muted">Payroll_ID: ' + payroll.id + '</small>';
                        html += '</td>';
                        html += '<td>';
                        html += '<strong>' + payroll.year + '/' + payroll.month + '</strong><br>';
                        html += '<small class="text-muted">' + (payroll.run_date || '') + '</small>';
                        html += '</td>';
                        html += '<td>';
                        html += '<strong>TOTAL: ' + (payroll.total_days || 0) + '</strong><br>';
                        html += '<small class="text-muted">LAG: ' + (payroll.balance_days || 0) + '</small>';
                        html += '</td>';
                        html += '<td>' + (payroll.net_salary || 0) + '</td>';
                        html += '<td>' + (payroll.payable_salary || 0) + '</td>';
                        html += '<td>' + statusBadge + '</td>';
                        html += '<td class="text-center">';
                        html += '<div class="btn-group btn-group-sm" role="group">';
                        
                        // View button - Always show
                        html += '<button type="button" class="btn btn-outline-primary view-payroll" ';
                        html += 'data-payroll-id="' + payroll.id + '" ';
                        html += 'data-bs-toggle="tooltip" title="View Payroll">';
                        html += '<i class="fa-solid fa-eye"></i></button>';
                        
                        // Print button - Show only if NOT pending
                        if (payroll.status.toLowerCase() !== 'pending') {
                            html += '<button type="button" class="btn btn-outline-success print-payslip" ';
                            html += 'data-payroll-id="' + payroll.id + '" ';
                            html += 'data-bs-toggle="tooltip" title="Print Payslip">';
                            html += '<i class="fa-solid fa-print"></i></button>';
                        }
                        
                        // Delete button - Show ONLY if status is Pending
                        if (payroll.status.toLowerCase() === 'pending') {
                            html += '<button type="button" class="btn btn-outline-danger delete-payroll" ';
                            html += 'data-payroll-id="' + payroll.id + '" ';
                            html += 'data-bs-toggle="tooltip" title="Delete Payroll">';
                            html += '<i class="fa-solid fa-trash"></i></button>';
                        }
                        
                        html += '</div></td>';
                        html += '</tr>';
                    });
                    
                    $('#employee-table tbody').html(html);
                    $('#visible-count').text(response.payrollDetails.length);
                    
                    // Reinitialize tooltips
                    $('[data-bs-toggle="tooltip"]').tooltip();
                } else {
                    $('#employee-table tbody').html('<tr><td colspan="7" class="text-center">No records found for the selected filters</td></tr>');
                    $('#visible-count').text('0');
                }
                
                // Update stats if provided
                if (response.statuses) {
                    $('.col-lg-3:eq(0) .card-body h4').text(response.statuses.total_employees || 0);
                    $('.col-lg-3:eq(1) .card-body h4').text(response.statuses.processed_payroll || 0);
                    $('.col-lg-3:eq(1) .card-body p').html('Processed Payroll: ₹' + (response.statuses.total_paid || '0.00'));
                    $('.col-lg-3:eq(2) .card-body h4').text(response.statuses.pending_payroll || 0);
                    $('.col-lg-3:eq(2) .card-body p').html('Unreleased Payrolls: ₹' + (response.statuses.total_pending_amount || '0.00'));
                    $('.col-lg-3:eq(3) .card-body h3').text('₹' + parseFloat(response.statuses.total_payout || 0).toFixed(2));
                }
            } else {
                alert(response.error || 'Failed to load payroll records');
            }
        },
        error: function(xhr, status, error) {
            $('#loadingModal').modal('hide');
            console.error('AJAX Error:', {
                status: status,
                error: error,
                responseText: xhr.responseText,
                statusCode: xhr.status
            });
            
            var errorMsg = 'Error loading payroll records.';
            if (xhr.responseText) {
                errorMsg += '\n\nDetails: ' + xhr.responseText;
            }
            alert(errorMsg);
        }
    });
 }

    // Generate Payroll Button Click
    $('#generatePayrollBtn').on('click', function() {
        var month = $('#filterMonth').val();
        var year = $('#filterYear').val();
        
        if (!month || !year) {
            alert('Please select both Month and Year to generate payroll');
            return;
        }
        
        if (!confirm('Are you sure you want to generate payroll for ' + month + '/' + year + '?')) {
            return;
        }
        
        // Show loading modal
        $('#loading-text').text('Generating payroll...');
        $('#loadingModal').modal('show');
        
        // Disable button
        $('#generatePayrollBtn').prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i> Generating...');
        
        // Send AJAX request
        $.ajax({
            url: 'index.php?route=payroll/payroll&user_token={{ user_token }}',
            type: 'POST',
            data: {
                year: year,
                month: month
            },
            success: function() {
                // After generation, refresh the filter to show new data
                $('#loadingModal').modal('hide');
                $('#generatePayrollBtn').prop('disabled', false).html('<i class="fa-solid fa-calculator"></i> Generate Payroll');
                
                // Call filter function to reload the data
                filterEmployees();
            },
            error: function() {
                $('#loadingModal').modal('hide');
                $('#generatePayrollBtn').prop('disabled', false).html('<i class="fa-solid fa-calculator"></i> Generate Payroll');
                
                // Still try to refresh the data
                filterEmployees();
            }
        });
    });
</script>
