                            productData = res.product;
                        } else if (res.data) {
                            productData = Array.isArray(res.data) ? res.data[0] : res.data;
                        } else if (res.product_id || res.id) {
                            productData = res;
                        }
                    }
                    if (productData) {
                        renderProductForm(productData);
                    } else {
                        if (typeof toastr !== 'undefined') {
