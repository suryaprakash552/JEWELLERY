         function handleSearchKeypress(event, inputElement) {
             const autocompleteList = document.getElementById('main_search_autocomplete_list');
             const hasList = autocompleteList && autocompleteList.style.display === 'block';
             if (event.key === 'ArrowDown' && hasList) {
                 event.preventDefault();
                 moveAutocompleteSelection(1);
                 return;
             }
             if (event.key === 'ArrowUp' && hasList) {
                 event.preventDefault();
                 moveAutocompleteSelection(-1);
                 return;
             }
             if (event.key === 'Enter') {
                 event.preventDefault();
                 const selectedItem = getSelectedAutocompleteItem();
                 if (selectedItem) {
                     selectSearchAutocompleteProduct(selectedItem.dataset.productId);
                     return;
                 }
                 const searchTerm = inputElement.value.trim();
                 const firstItem = document.querySelector('#main_search_autocomplete_list li[data-product-id]');
                 if (firstItem) {
                     selectSearchAutocompleteProduct(firstItem.dataset.productId);
                     return;
                 }
                 if (searchTerm.length >= 6) {
                     findProductBySKU(searchTerm).then(function(product) {
                         if (product) {
                             addProductToCart(product);
                             inputElement.value = '';
                         } else if (searchTerm.length > 0) {
                             updateSearchAutocomplete(searchTerm, true);
                         }
                     });
                 } else if (searchTerm.length > 0) {
                     updateSearchAutocomplete(searchTerm, true);
                 }
             }
         }
         function findProductBySKU(sku) {
             if (!sku) return Promise.resolve(null);
             const url =
                 'index.php?route=extension/purpletree_pos/pos/home|getProductBySku&sku=' +
                 encodeURIComponent(sku);
             return new Promise(function (resolve) {
                 $.ajax({
                     url: url,
                     type: 'get',
                     dataType: 'json',
                     success: function (products) {
                         if (products.length === 1) {
                             resolve(products[0]);
                         } else if (products.length > 1) {
                             renderSearchAutocomplete(products, sku, true);
                             resolve(null);
                         } else {
                             resolve(null);
                         }
                     },
                     error: function () {
                         resolve(null);
                     }
                 });
             });
         }

         function updateSearchAutocomplete(searchTerm, showNoResults = false) {
             const autocompleteList = document.getElementById('main_search_autocomplete_list');
             if (!autocompleteList) return;
             if (!searchTerm) {
                 autocompleteList.innerHTML = '';
                 autocompleteList.style.display = 'none';
                 return;
             }

             $.ajax({
                 url: 'index.php?route=extension/purpletree_pos/pos/home|searchProducts&term=' + encodeURIComponent(searchTerm),
                 type: 'get',
                 dataType: 'json',
                 success: function(products) {
                     renderSearchAutocomplete(products || [], searchTerm, showNoResults);
                 },
                 error: function() {
                     renderSearchAutocomplete([], searchTerm, showNoResults);
                 }
             });
         }

         function renderSearchAutocomplete(products, searchTerm, showNoResults) {
             const autocompleteList = document.getElementById('main_search_autocomplete_list');
             if (!autocompleteList) return;
             autocompleteList.innerHTML = '';
             if (!products || products.length === 0) {
                 if (showNoResults) {
                     autocompleteList.innerHTML = '<li class="dropdown-item no-results" style="cursor:default; color:#8a93a2;">No products found</li>';
                     autocompleteList.style.display = 'block';
                 } else {
                     autocompleteList.style.display = 'none';
                 }
                 return;
             }
             products.forEach(function(product) {
                 const productId = product.product_id || product.productid || '';
                 const productName = product.name || product.heading_title || 'Unknown Product';
                 const productModel = product.model || 'N/A';
                 const productPrice = product.price || 0;
                 const productQuantity = product.pos_quantity || product.posquantity || product.quantity || 0;
                 const formattedPrice = '₹' + parseFloat(productPrice).toFixed(2);
                 const item = document.createElement('li');
                 item.className = 'dropdown-item' + (productQuantity > 0 ? '' : ' disabled');
                 item.setAttribute('data-product-id', productId);
                 item.style.borderBottom = '1px solid #2a3040';
                 item.innerHTML =
                     '<span class="cell" title="' + productName + '">' + productName + '</span>' +
                     '<span class="cell" title="' + productModel + '">' + productModel + '</span>' +
                     '<span class="cell quantity" title="' + productQuantity + '">' + productQuantity + '</span>' +
                     '<span class="cell price" title="' + formattedPrice + '">' + formattedPrice + '</span>';
                 if (productQuantity > 0) {
                     item.addEventListener('click', function() {
                         selectSearchAutocompleteProduct(productId);
                     });
                 }
                 autocompleteList.appendChild(item);
             });

             autocompleteList.style.display = products.length ? 'block' : 'none';
         }

         function selectSearchAutocompleteProduct(productId) {
             if (!productId) return;
             const searchTerm = document.getElementById('pos_search').value.trim();
             $.ajax({
                 url: 'index.php?route=extension/purpletree_pos/pos/home|searchProducts&term=' + encodeURIComponent(searchTerm),
                 type: 'get',
                 dataType: 'json',
                 success: function(products) {
                     const product = (products || []).find(function(p) {
                         return String(p.product_id) === String(productId) || String(p.productid) === String(productId);
                     });
                     if (product) {
                         allProductsCount.push(product);
                         localStorage.setItem('allProductsCount', JSON.stringify(allProductsCount));
                         addProductToCart(product);
                         document.getElementById('pos_search').value = '';
                         hideSearchAutocomplete();
                     }
                 }
             });
         }

         function getSelectedAutocompleteItem() {
             const autocompleteList = document.getElementById('main_search_autocomplete_list');
             if (!autocompleteList) return null;
             return autocompleteList.querySelector('li.dropdown-item.active');
         }

         function moveAutocompleteSelection(direction) {
             const autocompleteList = document.getElementById('main_search_autocomplete_list');
             if (!autocompleteList) return;
             const items = Array.from(autocompleteList.querySelectorAll('li.dropdown-item:not(.disabled)'));
             if (!items.length) return;
             let currentIndex = items.findIndex(item => item.classList.contains('active'));
             if (currentIndex >= 0) {
                 items[currentIndex].classList.remove('active');
             }
             const nextIndex = (currentIndex + direction + items.length) % items.length;
             const nextItem = items[nextIndex];
             if (nextItem) {
                 nextItem.classList.add('active');
                 nextItem.scrollIntoView({ block: 'nearest' });
             }
         }

