  <script type="text/javascript"><!--
// IE and Edge fix!

$('input[name=\'filter_operatorname\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=recharge/rechargecommission/autocompleteform&user_token={{ user_token }}&packageid={{ packageid }}&filter_operatorname=' +  encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
				  
					return {
						label: item['operatorname'],
						value: item['operater_id']
					}
				}));
			}
		});
	},
	
	'select': function(item) {
		$('input[name=\'filter_operatorname\']').val(item['label']);
	}
});

