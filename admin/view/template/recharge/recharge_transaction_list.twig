  <script type="text/javascript"><!--
$('#button-filter').on('click', function() {
	var url = '';
    
    var filter_fdate = $('input[name=\'filter_fdate\']').val();

	if (filter_fdate) {
		url += '&filter_fdate=' + encodeURIComponent(filter_fdate);
	}
	
	var filter_tdate = $('input[name=\'filter_tdate\']').val();

	if (filter_tdate) {
		url += '&filter_tdate=' + encodeURIComponent(filter_tdate);
	}
	
	var filter_customerid = $('input[name=\'filter_customerid\']').val();

	if (filter_customerid) {
		url += '&filter_customerid=' + encodeURIComponent(filter_customerid);
	}

	var filter_rechargenumber = $('input[name=\'filter_rechargenumber\']').val();

	if (filter_rechargenumber) {
		url += '&filter_rechargenumber=' + encodeURIComponent(filter_rechargenumber);
	}

	var filter_amount = $('input[name=\'filter_amount\']').val();

	if (filter_amount) {
		url += '&filter_amount=' + encodeURIComponent(filter_amount);
	}
	var filter_operator = $('input[name=\'filter_operator\']').val();

	if (filter_operator) {
		url += '&filter_operator=' + encodeURIComponent(filter_operator);
	}
	var filter_apirequestid = $('input[name=\'filter_apirequestid\']').val();

	if (filter_apirequestid) {
		
		url += '&filter_apirequestid=' + encodeURIComponent(filter_apirequestid);
	}
    
    var filter_customer_group_id= $('select[name=\'filter_customer_group_id\']').val();

	if (filter_customer_group_id !== '') {
		
		url += '&filter_customer_group_id=' + encodeURIComponent(filter_customer_group_id);
	}
    
	var filter_rechargetype = $('input[name=\'filter_rechargetype\']').val();

	if (filter_rechargetype) {
		url += '&filter_rechargetype=' + encodeURIComponent(filter_rechargetype);
	}
	
	var filter_ourrequestid = $('input[name=\'filter_ourrequestid\']').val();

	if (filter_ourrequestid) {
		url += '&filter_ourrequestid=' + encodeURIComponent(filter_ourrequestid);
	}

	var filter_status = $('select[name=\'filter_status\']').val();

	if (filter_status !== '') {
		url += '&filter_status=' + encodeURIComponent(filter_status);
	}

	location = 'index.php?route=recharge/r_history&user_token={{ user_token }}' + url;
});
//--></script> 
