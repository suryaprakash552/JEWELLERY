                            element.after('<div class="text-danger">' + json['error']['option'][i] + '</div>');
                        }
                    }
                }
                
                if (json['error']['store']) {
                    $('#fieldmanager .modal-body').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json['error']['store'] + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                }
                
                if (json['error']['supplier']) {
                    $('#fieldmanager .modal-body').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> ' + json['error']['supplier'] + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                }
                
                // Scroll to first error
                $('#fieldmanager .modal-body').animate({ scrollTop: 0 }, 300);
                
            } else {
                console.log('Product added successfully!');
                
                // Close modal
                var modalElement = document.getElementById('fieldmanager');
                if (modalElement) {
                    var modal = bootstrap.Modal.getInstance(modalElement);
                    if (modal) {
                        modal.hide();
                    }
                }
                
                // Clear form
                $('#form-order_product')[0].reset();
                $('#option').html('');
                $('input[name="product"]').val('');
                $('input[name="product_id"]').val('');
                $('input[name="quantity"]').val('1');
                $('input[name="stock"]').val('');
                if ($('#pimage').length) {
                    $('#pimage').html('');
                }
                
                // Show success message
                $('#content > .container-fluid').prepend('<div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> Product added successfully! <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
                
                // Refresh product list
                setTimeout(function() {
                    refresh_products();
                }, 200);
            }
        },
        error: function(xhr, ajaxOptions, thrownError) {
            console.error('=== AJAX Error ===');
            console.error('Error:', thrownError);
            console.error('Status:', xhr.statusText);
            console.error('Response:', xhr.responseText);
            
            $('#fieldmanager .modal-body').prepend('<div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> Error: ' + thrownError + ' <button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>');
        }
    });
});

