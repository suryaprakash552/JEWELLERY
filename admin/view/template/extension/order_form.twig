// Calculate Price from Sale Price and Discount
function calculatePriceFromDiscount(sale_price, discount) {
    var salePrice = parseFloat(sale_price) || 0;
    var discountPercent = parseFloat(discount) || 0;
    
    // Formula: Discount Amount = Sale Price × (Discount% ÷ 100)
    var discountAmount = (salePrice * discountPercent) / 100;
    
    // Final Price = Sale Price - Discount Amount
    var finalPrice = salePrice - discountAmount;
    
    console.log('Calculating Price: Sale=' + salePrice + ', Discount=' + discountPercent + '%, Amount=' + discountAmount + ', Final=' + finalPrice);
    
    return finalPrice.toFixed(2);
}

// Calculate Discount from Sale Price and Price
function calculateDiscountFromPrice(sale_price, price) {
    var salePrice = parseFloat(sale_price) || 0;
    var finalPrice = parseFloat(price) || 0;
    
    if (salePrice === 0) return '0.00';
    
    // Discount Amount = Sale Price - Final Price
    var discountAmount = salePrice - finalPrice;
    
    // Discount % = (Discount Amount ÷ Sale Price) × 100
    var discountPercent = (discountAmount / salePrice) * 100;
    
    console.log('Calculating Discount: Sale=' + salePrice + ', Price=' + finalPrice + ', Discount=' + discountPercent + '%');
    
    return discountPercent.toFixed(2);
}

// Update row total display
function updateRowTotal(row) {
    var price = parseFloat($('input[name="product[' + row + '][price]"]').val()) || 0;
    var quantity = parseInt($('input[name="product[' + row + '][quantity]"]').val()) || 1;
    var total = (price * quantity).toFixed(2);
    
    $('.product-total[data-row="' + row + '"]').text('₹' + total);
    console.log('Row ' + row + ' Total: ' + total);
}

// Save and refresh
function saveAndRefresh() {
    clearTimeout(window.saveTimer);
    window.saveTimer = setTimeout(function() {
        var supplier_id = $('input[name="supplier_id"]').val();
        if (!supplier_id || supplier_id == '' || supplier_id == '0') {
            console.log('No supplier, skipping save');
            return;
        }
        
        console.log('Saving products...');
        
        $.ajax({
            url: 'index.php?route=extension/me_purchase_order.addproduct&user_token={{ user_token }}&store_id=0&supplier_id=' + supplier_id,
            type: 'post',
            data: $('#cart input, #cart select, #cart textarea').serialize(),
            dataType: 'json',
            success: function(json) {
                if (!json['error']) {
                    console.log('Products saved, refreshing...');
                    refresh_products();
                    // Add totals update here
                    setTimeout(function() {
                        totals();
                    }, 300);
                } else {
                    console.error('Save error:', json['error']);
                }
            },
            error: function(xhr, status, error) {
                console.error('Save AJAX error:', error);
            }
        });
    }, 1500);
}

