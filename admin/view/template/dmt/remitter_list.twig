{{ header }}{{ column_left }}
 <style>
.my-filter-input {
    display: none;
}
.my-filter{
    display: block;    
    padding: 10px;
    margin: 0 0 1px 0;
    cursor: pointer;
    background: #6AAB95;
    border: 1px solid #A7A7A7;
    border-radius: 3px;
    color: #FFF;
    transition: ease .5s;

}
.my-filter:hover {
    background: #4E8774;
}

.my-filter-content {
    background: #313941;
    padding: 25px 5px;
    border: 1px solid #A7A7A7;
    margin: 0 0 1px 0;
    border-radius: 3px;
    
}

.my-filter-input + .my-filter + .my-filter-content {
    display: none;
    padding-right: -2px;
}

.my-filter-input:checked + .my-filter + .my-filter-content {
    display: block;
}

.myfilter-container
{
    padding-left: 250px;
}
</style>
<div id="content"><br><br>
  <div class="page-header">
    <div class="container-fluid myfilter-container">
      <div class="pull-right">
       <!-- <button type="button" data-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-product').toggleClass('hidden-sm hidden-xs');" class="btn btn-default hidden-md hidden-lg"><i class="fa fa-filter"></i></button> -->
        <!--<a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="submit" form="form-product" formaction="{{ copy }}" data-toggle="tooltip" title="{{ button_copy }}" class="btn btn-default"><i class="fa fa-copy"></i></button>-->
       <!-- <button type="button" form="form-product" formaction="{{ delete }}" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-product').submit() : false;"><i class="fa fa-trash-o"></i></button> -->
      </div>
           <h1>{{ heading_title }}</h1>
            <ol class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}
            <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid myfilter-container">{% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="row">
      <div id="filter-product" class="col-sm-12 hidden-sm hidden-xs">
        <div class="panel panel-default">
        <input class="my-filter-input"type="checkbox" id="title2" />
        <label class='my-filter panel-heading'for="title2" style="background-color:#313941;color:white;"><i class="fa fa-filter"></i> {{ text_filter }}<span style="float:right;"><i class="fa fas fa-chevron-down fa-1x" ></i></span>
        </label>
        <div class="my-filter-content panel-body">
            <div class="row mb-2" style="row-gap: 20px;margin-left:150px">
            <div class="col-sm-5">
              <label class="control-label" style="color:white" for="input-fdate">{{ entry_fdate }}</label>
              <input type="date" name="filter_fdate" style="color:black" value="{{ filter_fdate }}" placeholder="{{ entry_fdate }}" id="input-fdate" class="form-control" />
            </div>
            <div class="col-sm-5">
              <label class="control-label" style="color:white" for="input-tdate">{{ entry_tdate }}</label>
              <input type="date" name="filter_tdate"  style="color:black" value="{{ filter_tdate }}" placeholder="{{ entry_tdate }}" id="input-tdate" class="form-control" />
            </div>
            <div class="col-sm-5">
              <label class="control-label" style="color:white" for="input-customerid">{{ entry_customerid }}</label>
              <input type="text" name="filter_customerid" style="color:black" value="{{ filter_customerid }}" placeholder="{{ entry_customerid }}" id="input-customerid" class="form-control" />
            </div>
            <div class="col-sm-5">
              <label class="control-label" style="color:white" for="input-snumber">{{ entry_snumber }}</label>
              <input type="text"  style="color:black" name="filter_snumber" value="{{ filter_snumber }}" placeholder="{{ entry_snumber }}" id="input-snumber" class="form-control" />
            </div>
            <div class="col-sm-5">
              <label class="control-label"  style="color:white" for="input-status">{{ entry_status }}</label>
              <select name="filter_status" id="input-status" class="form-control" style="color:black">
                <option value=""></option>
                 {% if filter_status == '1' %}
                 <option value="1" selected="selected">{{ text_enabled }}</option>
                 {% else %}
                 <option value="1">{{ text_enabled }}</option>
                 {% endif %}
                 {% if filter_status == '0' %}
                 <option value="0" selected="selected">{{ text_disabled }}</option>
                 {% else %}
                 <option value="0">{{ text_disabled }}</option>
                {% endif %}
              </select>
              
            </div> 
            <div class="form-group col-sm-2" style="margin-top:20px">
              <button type="button" id="button-filter" style="float:right;background-color:white;color:black;" class="btn btn-default"><i class="fa fa-filter"></i> {{ button_filter }}</button>
            </div>
            </div>
        </div>
        </div>
      </div>
      <div class="col-sm-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3  style="color:white" class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
          </div>
          <div class="panel-body">
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-product">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead style="background-color:#861f41">
                    <tr>
                      <!--<td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td> -->
                      <td class="text-center" style="color:white">{{colum_srno}}</td>
                      <!--<td class="text-center" style="color:black">{{ column_action }}</td> -->
                      <td class="text-center" style="color:white">{{colum_customerid}}</td>
                      <td class="text-center">{% if sort == 'p.number' %} <a style="color:white" href="{{ sort_number }}" class="{{ order|lower }}">{{ column_number }}</a> {% else %} <a style="color:white" href="{{ sort_number }}">{{ column_number }}</a> {% endif %}</td>
                      <td class="text-center">{% if sort == 'p.name' %} <a style="color:white" href="{{ sort_name }}" class="{{ order|lower }}">{{ column_name }}</a> {% else %} <a  style="color:white"href="{{ sort_name }}">{{ column_name }}</a> {% endif %}</td>
                      <td class="text-center">{% if sort == 'p.created' %} <a  style="color:white"href="{{ sort_created }}" class="{{ order|lower }}">{{ column_created }}</a> {% else %} <a style="color:white" href="{{ sort_created }}">{{ column_created }}</a> {% endif %}</td>
                      <td class="text-center" style="color:white">{{colum_consumed}}</td>
                      <td class="text-center" style="color:white">{{colum_kyc}}</td>
                      <td class="text-center">{% if sort == 'p.status' %} <a style="color:white" href="{{ sort_status }}" class="{{ order|lower }}">{{ column_status }}</a> {% else %} <a style="color:white" href="{{ sort_status }}">{{ column_status }}</a> {% endif %}</td>
                      <td class="text-center" style="color:white">{{colum_source}}</td>
                    </tr>
                  </thead>
                  <tbody>
                  
                  {% if products %}
                  {% for product in products %}
                  <tr>
                   {# <td class="text-center">{% if product.id in selected %}
                      <input type="checkbox" name="selected[]" value="{{ product.id }}" checked="checked" />
                      {% else %}
                      <input type="checkbox" name="selected[]" value="{{ product.id }}" />
                      {% endif %}</td>#}
                    <td class="text-left">{{ product.srno }}</td>
                     <!--<td class="text-right"><a href="{{ product.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a></td> -->
                    <td class="text-left">{{ product.customerid }}</td>
                    <td class="text-left">{{ product.number }}</td>
                    <td class="text-left">{{ product.name }}</td>
                    <td class="text-left">{{ product.created }}</td>
                    <td class="text-left">{{ product.consumed }}</td>
                    <td class="text-left">{{ product.kyc}}</td>
                    <td class="text-left">{{ product.status }}</td>
                    <td class="text-left">{{ product.source }}</td>
                 </tr>
                  {% endfor %}
                  {% else %}
                  <tr>
                    <td class="text-center" colspan="11">{{ text_no_results }}</td>
                  </tr>
                  {% endif %}
                    </tbody>
                  
                </table>
              </div>
            </form>
            <div class="row">
              <div class="col-sm-6 text-start">{{ pagination }}</div>
              <div class="col-sm-6 text-end" style="color:white">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script type="text/javascript"><!--
$('#button-filter').on('click', function() {
	var url = '';

	var filter_fdate = $('input[name=\'filter_fdate\']').val();

	if (filter_fdate) {
		url += '&filter_fdate=' + encodeURIComponent(filter_fdate);
	}
	
	var filter_tdate = $('input[name=\'filter_tdate\']').val();

	if (filter_tdate) {
		url += '&filter_tdate=' + encodeURIComponent(filter_tdate);
	}

	var filter_customerid = $('input[name=\'filter_customerid\']').val();

	if (filter_customerid) {
		url += '&filter_customerid=' + encodeURIComponent(filter_customerid);
	}

	var filter_snumber = $('input[name=\'filter_snumber\']').val();

	if (filter_snumber) {
		url += '&filter_snumber=' + encodeURIComponent(filter_snumber);
	}
	
	var filter_status = $('select[name=\'filter_status\']').val();

	if (filter_status !== '') {
		url += '&filter_status=' + encodeURIComponent(filter_status);
	}

	location = 'index.php?route=dmt/remitter&user_token={{ user_token }}' + url;
});
//--></script> 
  <script type="text/javascript"><!--
// IE and Edge fix!
$('button[form=\'form-product\']').on('click', function(e) {
	$('#form-product').attr('action', $(this).attr('formaction'));
});
  
$('input[name=\'filter_name\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=catalog/product/autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['product_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_name\']').val(item['label']);
	}
});

$('input[name=\'filter_model\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=catalog/product/autocomplete&user_token={{ user_token }}&filter_model=' +  encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['model'],
						value: item['product_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_model\']').val(item['label']);
	}
});
//--></script></div>
{{ footer }} 