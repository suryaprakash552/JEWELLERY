function addbulkproduct(url) {
	$('.pagination-results').remove();
	$.ajax({
		url: url,
		type: 'post',
		dataType: 'json',
		crossDomain: true,
		beforeSend: function() {
			
		},
		complete: function() {
			
		},
		success: function(json) {
			html = '';
			if(json['products'].length > 0){
				for(i in json['products']){
					var product = json['products'][i];
					html += '<tr id="sellerproduct'+ i +'">';
					html += '<td><a href="' + product['image'] + '" target="_blank"><img src="' + product['image'] + '" alt="' + product['name'] + '" style="width:50px!important"></a><input type="hidden" name="stock" value="' + product['quantity'] + '" /></td>';
					html += '<td>'+ product['name'] +' <input type="hidden" name="product_id" value="' + product['product_id'] + '" /></td>';
					html += '<td>'+ product['model'] +'</td>';
					html += '<td>'+ product['sale_price'] +' <input type="hidden" name="sale_price" value="'+ product['sale_price'] +'" /></td>';
					html += '<td>'+ product['price'] +' <input type="hidden" name="price" value="'+ product['price'] +'" /></td>';
					html += '<td>'+ product['quantity'] +'</td>';
					html += '<td><input type="text" name="quantity" value="1" class="form-control text-right" /></td>';
					html += '<td>';
					if (product['option'] != '') {
						html += '<a onclick="showoption(' + i + ');" class="btn btn-primary">Option</a>';
						html += '<div class="productoptions hide">';
						for (j = 0; j < product['option'].length; j++) {
							option = product['option'][j];

							if (option['type'] == 'select' && option['required'] == 1) {
								html += '<div class="form-group' + (option['required'] ? ' required' : '') + '">';
								html += '  <label class="control-label" for="input-bulk-option' + option['product_option_id'] + '">' + option['name'] + '</label>';
								html += '  <div class="">';
								html += '    <select name="option[' + option['product_option_id'] + ']" id="input-bulk-option' + option['product_option_id'] + '" class="form-control">';
								html += '      <option value="">{{ text_select }}</option>';

								for (k = 0; k < option['product_option_value'].length; k++) {
									option_value = option['product_option_value'][k];

									html += '<option value="' + option_value['product_option_value_id'] + '">' + option_value['name'];

									if (option_value['price']) {
										html += ' (' + option_value['price_prefix'] + option_value['price'] + ') (' + option_value['quantity'] + ')';
									} else {
										html += ' (' + option_value['quantity'] + ')';
									}

									html += '</option>';
								}

								html += '    </select>';
								html += '  </div>';
								html += '</div>';
							}
							
							if (option['type'] == 'radio' && option['required'] == 1) {
								html += '<div class="form-group' + (option['required'] ? ' required' : '') + '">';
								html += '  <label class="control-label" for="input-bulk-option' + option['product_option_id'] + '">' + option['name'] + '</label>';
								html += '  <div class="">';
								html += '    <select name="option[' + option['product_option_id'] + ']" id="input-bulk-option' + option['product_option_id'] + '" class="form-control">';
								html += '      <option value="">{{ text_select }}</option>';

								for (k = 0; k < option['product_option_value'].length; k++) {
									option_value = option['product_option_value'][k];

									html += '<option value="' + option_value['product_option_value_id'] + '">' + option_value['name'];

									if (option_value['price']) {
										html += ' (' + option_value['price_prefix'] + option_value['price'] + ') (' + option_value['quantity'] + ')';
									} else {
										html += ' (' + option_value['quantity'] + ')';
									}

									html += '</option>';
								}

								html += '    </select>';
								html += '  </div>';
								html += '</div>';
							}

							if (option['type'] == 'checkbox' && option['required'] == 1) {
								html += '<div class="form-group' + (option['required'] ? ' required' : '') + '">';
								html += '  <label class="control-label">' + option['name'] + '</label>';
								html += '  <div class="">';
								html += '    <div id="input-bulk-option' + option['product_option_id'] + '">';

								for (k = 0; k < option['product_option_value'].length; k++) {
									option_value = option['product_option_value'][k];

									html += '<div class="checkbox">';

									html += '  <label><input type="checkbox" name="option[' + option['product_option_id'] + '][]" value="' + option_value['product_option_value_id'] + '" /> ' + option_value['name'];

									if (option_value['price']) {
										html += ' (' + option_value['price_prefix'] + option_value['price'] + ')';
									}

									html += '  </label>';
									html += '</div>';
								}

								html += '    </div>';
								html += '  </div>';
								html += '</div>';
							}
						}
						html += '</div>';
					}
					html += '</td>';
					html += '<td><a class="btn btn-primary" onclick="addmoreprduct('+ i +');">Add Product</a></td>';
					html += '</tr>';
				}
			} else {
				html += '<tr>';
				html += '<td colspan="7" class="text-center">{{ text_no_products }}</td>';
				html += '</tr>';
			}
			
			$('.sellerproducts').html(html);

			if (json['pagination'] || json['results']) {
				html = '<div class="row pagination-results">';
				if (json['pagination']) {
	            	html += '  <div class="col-sm-6 text-left">'+ json['pagination'] +'</div>';
	        	} else {
	        		html += '  <div class="col-sm-6 text-left"></div>';
	        	}
	            html += '  <div class="col-sm-6 text-right">'+ json['results'] +'</div>';
	            html += '</div>';

	            $('#form-bulk_order_product').append(html);
			}
		},
	});
}
