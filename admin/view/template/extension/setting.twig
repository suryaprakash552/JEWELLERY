	html += '  <input type="text" name="me_purchase_order_setting_payment_method[' + payment_method_row + '][name]" value="" placeholder="{{ entry_name }}" class="form-control" /><input type="hidden" name="me_purchase_order_setting_payment_method[' + payment_method_row + '][payment_method_id]" value="' + payment_method_row + '">';
	html += '  </td>';
	html += '<td class="text-left">';
	html += '	<input type="text" name="me_purchase_order_setting_payment_method[' + payment_method_row + '][sort_order]" value="" placeholder="{{ entry_sort_order }}" class="form-control" />';
	html += '</td>';
	html += '  <td class="text-left">';
	html += '<select name="me_purchase_order_setting_payment_method[' + payment_method_row + '][status]" class="form-control">';
	html += ' <option value="1">{{ text_enabled }}</option>';
	html += ' <option value="0">{{ text_disabled }}</option>';
	html += '</select>';
	html += '  </td>';
	html += '  <td class="text-left"><button type="button" onclick="$(\'#payment_method-row' + payment_method_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
	html += '</tr>';	
	
	$('#payment_method tbody').append(html);
	
	payment_method_row++;
}
//--></script>
<script type="text/javascript"><!--
var shipping_method_row = {{ shipping_method_row }};

function addshippingmethodRow() {
	html  = '<tr id="shipping_method-row' + shipping_method_row + '">';	
    html += '  <td class="text-left">';
	html += '  <input type="text" name="me_purchase_order_setting_shipping_method[' + shipping_method_row + '][name]" value="" placeholder="{{ entry_name }}" class="form-control" /><input type="hidden" name="me_purchase_order_setting_shipping_method[' + shipping_method_row + '][shipping_method_id]" value="' + shipping_method_row + '">';
	html += '  </td>';
	html += '<td class="text-left">';
	html += '	<input type="text" name="me_purchase_order_setting_shipping_method[' + shipping_method_row + '][price]" value="" placeholder="{{ entry_price }}" class="form-control" />';
	html += '</td>';
	html += '<td class="text-left">';
	html += '	<input type="text" name="me_purchase_order_setting_shipping_method[' + shipping_method_row + '][sort_order]" value="" placeholder="{{ entry_sort_order }}" class="form-control" />';
	html += '</td>';
	html += '  <td class="text-left">';
	html += '<select name="me_purchase_order_setting_shipping_method[' + shipping_method_row + '][status]" class="form-control">';
	html += ' <option value="1">{{ text_enabled }}</option>';
	html += ' <option value="0">{{ text_disabled }}</option>';
	html += '</select>';
	html += '  </td>';
	html += '  <td class="text-left"><button type="button" onclick="$(\'#shipping_method-row' + shipping_method_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
	html += '</tr>';	
	
	$('#shipping_method tbody').append(html);
	
	shipping_method_row++;
}
