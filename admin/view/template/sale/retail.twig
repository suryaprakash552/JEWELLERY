            ${parseFloat(r.balance) > 0 ? 
                `<button class="btn btn-xs btn-warning edit-due-btn" 
                    data-order="${r.order_id}" 
                    data-balance="${r.balance}" 
                    data-customer="${r.customer_id}">
                    <i class="fa fa-edit"></i>
                </button>` 
            : ''}
        </td>
