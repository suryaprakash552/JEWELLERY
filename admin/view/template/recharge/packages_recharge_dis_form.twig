    <div class="panel panel-default" style="margin-top:10px">
      <div class="panel-heading"> 
    <!--    <h3 class="panel-title"><i class="fa fa-pencil"></i> {{ text_form }}</h3> -->
      </div>
      <div class="panel-body">
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-product" class="form-horizontal">
          <ul class="nav nav-tabs">
        <!--  <h3>  <li class="active"><a href="#tab-discount" data-toggle="tab" style="color:white"><b> {{ tab_discount }}</b></a></li></h3> -->
          </ul>
          <div class="tab-content">
            <div class="tab-pane active" id="tab-discount">
              <div class="table-responsive">
                <table id="discount" class="table table-striped table-bordered table-hover "style="margin-top:20px">
                  <thead>
                    <tr>
                    
                      <td class="text-center" style="color:black;">{{ entry_operatorlist }}</td>
                      <td class="text-center" style="color:black;">{{ entry_start_limit }}</td>
                      <td class="text-center" style="color:black;">{{ entry_end_limit }}</td>
                      <td class="text-center" style="color:black;">{{ entry_commission }}</td>
                      <td class="text-center" style="color:black;">{{ entry_dt }}</td>
                      <td class="text-center" style="color:black;">{{ entry_sd }}</td>
                      <td class="text-center" style="color:black;">{{ entry_wt }}</td>
                      <td class="text-center" style="color:black;">{{ entry_admin }}</td>
                      <td class="text-center" style="color:black;">{{ entry_isflat }}</td>
                      <td class="text-center" style="color:black;">{{ entry_issurcharge }}</td>
                      <td class="text-center" style="color:black;">{{ entry_apiid }}</td>
                      <td class="text-center" style="color:black;">{{ entry_auto }}</td>
                      <td class="text-center" style="color:black;">{{ entry_mode }}</td>
                      <td></td>
                    </tr>
                  </thead>
                  <tbody>

                    {% set commission_row = 0 %}
                    {% for package_commission in package_commissions %}
                      <tr id="commission-row{{ commission_row }}">
                        <td class="text-left"><select name="package_commission[{{ commission_row }}][operatorid]" class="form-control">
                            {% for operator in operators %}
                              {% if operator.operatorid == package_commission.operater_id %}
                                <option value="{{ operator.operatorid }}" selected="selected">{{ operator.operatorname }}</option>
                              {% else %}
                                <option value="{{ operator.operatorid }}">{{ operator.operatorname }}</option>
                              {% endif %}
                            {% endfor %}
                          </select></td>
                        <td class="text-left"><input type="text" readonly name="package_commission[{{ commission_row }}][start_amount]" value="{{ package_commission.start_amount }}" placeholder="{{ entry_start_amount }}" class="form-control"/></td>
                        <td class="text-left"><input type="text" readonly name="package_commission[{{ commission_row }}][end_amount]" value="{{ package_commission.end_amount }}" placeholder="{{ entry_end_amount }}" class="form-control"/></td>
                        <td class="text-left"><input type="text" name="package_commission[{{ commission_row }}][commission]" value="{{ package_commission.commission }}" placeholder="{{ entry_commission_pla }}" class="form-control"/></td>
                        <td class="text-left"><input type="text" name="package_commission[{{ commission_row }}][dt]" value="{{ package_commission.dt }}" placeholder="{{ entry_dt_pla }}" class="form-control"/></td>
                        <td class="text-left"><input type="text" name="package_commission[{{ commission_row }}][sd]" value="{{ package_commission.sd }}" placeholder="{{ entry_sd_pla }}" class="form-control"/></td>
                        <td class="text-left"><input type="text" name="package_commission[{{ commission_row }}][wt]" value="{{ package_commission.wt }}" placeholder="{{ entry_wt_pla }}" class="form-control"/></td>
                        <td class="text-left"><input type="text" name="package_commission[{{ commission_row }}][admin_profit]" value="{{ package_commission.admin_profit }}" placeholder="{{ entry_admin_profit }}" class="form-control"/></td>
                        <td class="text-left"><select name="package_commission[{{ commission_row }}][isflat]" class="form-control">
                              {% if package_commission.isflat == 0 %}
                                <option value="0" selected="selected">{{ NO }}</option>
                                <option value="1">{{ YES }}</option>
                              {% else %}
                                <option value="1" selected="selected">{{ YES }}</option>
                                <option value="0">{{ NO }}</option>
                              {% endif %}
                          </select></td>
                          <td class="text-left"><select name="package_commission[{{ commission_row }}][issurcharge]" class="form-control">
                              {% if package_commission.issurcharge == 0 %}
                                <option value="0" selected="selected">{{ NO }}</option>
                                <option value="1">{{ YES }}</option>
                              {% else %}
                                <option value="1" selected="selected">{{ YES }}</option>
                                <option value="0">{{ NO }}</option>
                              {% endif %}
                          </select></td>
                        <td class="text-left"><select name="package_commission[{{ commission_row }}][apiid]" class="form-control">
                            {% for api in apis %}
                              {% if api.apiid == package_commission.apiid %}
                                <option value="{{ api.apiid }}" selected="selected">{{ api.comurl }}</option>
                              {% else %}
                                <option value="{{ api.apiid }}">{{ api.comurl }}</option>
                              {% endif %}
                            {% endfor %}
                          </select></td>
                       <td class="text-left"><select name="package_commission[{{ commission_row }}][auto_status]" class="form-control">
                              {% if package_commission.auto_status == 0 %}
                                <option value="0" selected="selected">{{ NO }}</option>
                                <option value="1">{{ YES }}</option>
                              {% else %}
                                <option value="1" selected="selected">{{ YES }}</option>
                                <option value="0">{{ NO }}</option>
                              {% endif %}
                          </select></td>
                        <td class="text-left"><select name="package_commission[{{ commission_row }}][mode]" class="form-control">
                              {% if package_commission.mode == 1 %}
                                <option value="1" selected="selected">{{ ONLINE }}</option>
                                <option value="0">{{ OFFLINE }}</option>
                              {% else %}
                                <option value="1">{{ ONLINE }}</option>
                                <option value="0" selected="selected">{{ OFFLINE }}</option>
                              {% endif %}
                          </select></td>
                        <td class="text-left"><button type="button" value="{{ package_commission.operater_id }}" name="package_commission[{{ commission_row }}]" onclick="confirm('{{ text_confirm }}')?removeRow({{package_commission.start_amount}},{{package_commission.end_amount}},{{package_commission.packageid}},{{commission_row}},this):false;" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>
                      </tr>
                      {% set commission_row = commission_row + 1 %}
                    {% endfor %}
                  </tbody>

                  <tfoot>
                    <tr>
                      <td colspan="13"></td>
                      <td class="text-left"><button type="button" onclick="addCommission();" data-toggle="tooltip" title="{{ button_discount_add }}" class="btn btn-primary"><i class="fa fa-plus-circle"></i></button></td>
                    </tr>
                  </tfoot>
                </table>
              </div>
            </div>
        <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right" style="color:white">{{ results }}</div>
            </div>
              
          </div>
        </form>
      </div>
    </div>
    </div>
    </div>
 </div>
