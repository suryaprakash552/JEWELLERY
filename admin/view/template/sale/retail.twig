//  Replace your existing #updateDue click handler
$(document).on('click', '#updateDue', function () {

    const order_id     = $('#edit_order_id').val();
    const customer_id  = $('#edit_customer_id').val();
    const amount       = parseFloat($('#edit_amount').val()) || 0;
    const payment_type = $('input[name="edit_payment_type"]:checked').val();

    function showMsg(text, type) {
        const colors = {
            error:   { bg: '#450a0a', color: '#fca5a5', border: '#dc2626' },
            success: { bg: '#052e16', color: '#86efac', border: '#16a34a' },
            info:    { bg: '#0c1a2e', color: '#facc15', border: '#ca8a04' }
        };
        const c = colors[type] || colors.error;
        $('#balance-modal-msg')
            .css({ background: c.bg, color: c.color, border: '1px solid ' + c.border })
            .html(text)
            .show();
    }

    if (!order_id) { showMsg('Order ID missing.', 'error'); return; }
    if (amount <= 0) { showMsg('Please enter a valid amount greater than 0.', 'error'); return; }

    $('#updateDue').prop('disabled', true).text('Saving...');
    $('#balance-modal-msg').hide();

    $.ajax({
        url: 'index.php?route=sale/retail.updateDueAmount&user_token={{ user_token }}',
        type: 'POST',
        dataType: 'json',
        data: { order_id, customer_id, amount, payment_type },
        success: function (json) {
            if (json.status) {
                showMsg('<i class="fa fa-check-circle"></i> Payment updated successfully!', 'success');
                setTimeout(function () {
                    bootstrap.Modal.getInstance(
                        document.getElementById('balanceModal')
                    ).hide();
                    loadTabData('salesprice');
                }, 1200);
                $('#updateDue').prop('disabled', false).html('<i class="fa fa-check"></i> OK');
            } else {
                // ✅ Fetch AEPS balance and show in error message
                fetch('index.php?route=sale/retail.getWalletBalance&user_token={{ user_token }}&order_id=' + order_id)
                    .then(res => res.json())
                    .then(data => {
                        const aeps = data.status ? parseFloat(data.aeps_amount).toFixed(2) : '0.00';
                        const aepsFloat = parseFloat(aeps);

                        if (aepsFloat <= 0) {
                            // ✅ AEPS is 0 — due is cleared
                            showMsg(
                                '<i class="fa fa-info-circle"></i> Your due is already cleared.' +
                                '<br><small>AEPS Wallet Balance: <strong>₹' + aeps + '</strong></small>',
                                'info'
                            );
                        } else {
                            // ✅ AEPS has value — show error with balance
                            showMsg(
                                '<i class="fa fa-times-circle"></i> ' + (json.error || 'Update failed') +
                                '<br><small>Available AEPS Wallet Balance: <strong>₹' + aeps + '</strong></small>',
                                'error'
                            );
                        }
                    })
                    .catch(() => {
                        showMsg('<i class="fa fa-times-circle"></i> ' + (json.error || 'Update failed'), 'error');
                    });
                $('#updateDue').prop('disabled', false).html('<i class="fa fa-check"></i> OK');
            }
        },
        error: function (xhr) {
            showMsg('<i class="fa fa-times-circle"></i> Server error: ' + xhr.status + ' ' + xhr.statusText, 'error');
            $('#updateDue').prop('disabled', false).html('<i class="fa fa-check"></i> OK');
        }
    });
});

