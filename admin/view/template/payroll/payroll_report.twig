<!-- admin/view/template/payroll/payroll_report.twig -->
{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        <div class="btn-group">
          <a href="{{ url('payroll/payroll', 'user_token=' ~ user_token) }}" class="btn btn-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Payroll
          </a>
          <button type="button" class="btn btn-success" onclick="window.print()">
            <i class="fa-solid fa-print"></i> Print Report
          </button>
        </div>
      </div>
      <h1>{{ title }}</h1>
      <ol class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid">
    <!-- Report Filters -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fa-solid fa-filter"></i> Report Filters
        </h3>
      </div>
      <div class="card-body">
        <form method="get" action="">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="row">
            <div class="col-md-3">
              <div class="form-group">
                <label for="report_year" class="form-label">Year</label>
                <select class="form-select" id="report_year" name="year">
                  {% for report_year in years %}
                  <option value="{{ report_year }}" {{ report_year == year ? 'selected' : '' }}>{{ report_year }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>
            {% if report_type == 'monthly' %}
            <div class="col-md-3">
              <div class="form-group">
                <label for="report_month" class="form-label">Month</label>
                <select class="form-select" id="report_month" name="month">
                  {% for key, month_name in months %}
                  <option value="{{ key }}" {{ key == month ? 'selected' : '' }}>{{ month_name }}</option>
                  {% endfor %}
                </select>
              </div>
            </div>
            {% endif %}
            <div class="col-md-3">
              <div class="form-group">
                <label for="report_type" class="form-label">Report Type</label>
                <select class="form-select" id="report_type" name="type">
                  <option value="monthly" {{ report_type == 'monthly' ? 'selected' : '' }}>Monthly Report</option>
                  <option value="annual" {{ report_type == 'annual' ? 'selected' : '' }}>Annual Report</option>
                </select>
              </div>
            </div>
            <div class="col-md-3 d-flex align-items-end">
              <div class="form-group w-100">
                <button type="submit" class="btn btn-primary w-100">
                  <i class="fa-solid fa-search"></i> Generate Report
                </button>
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Report Summary -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fa-solid fa-chart-bar"></i> Summary
        </h3>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-lg-3 col-md-6 mb-3">
            <div class="card bg-primary text-white">
              <div class="card-body text-center">
                <h4>{{ totals.employees ?: 0 }}</h4>
                <p class="mb-0">Total Employees</p>
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-3">
            <div class="card bg-success text-white">
              <div class="card-body text-center">
                <h4>${{ "%.2f"|format(totals.gross_salary ?: totals.annual_gross ?: 0) }}</h4>
                <p class="mb-0">Total Gross</p>
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-3">
            <div class="card bg-warning text-white">
              <div class="card-body text-center">
                <h4>${{ "%.2f"|format(totals.deductions ?: totals.annual_deductions ?: 0) }}</h4>
                <p class="mb-0">Total Deductions</p>
              </div>
            </div>
          </div>
          <div class="col-lg-3 col-md-6 mb-3">
            <div class="card bg-info text-white">
              <div class="card-body text-center">
                <h4>${{ "%.2f"|format(totals.net_salary ?: totals.annual_net ?: 0) }}</h4>
                <p class="mb-0">Total Net Pay</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Report Data -->
    <div class="card">
      <div class="card-header">
        <h3 class="card-title">
          <i class="fa-solid fa-table"></i> Detailed Report
        </h3>
      </div>
      <div class="card-body">
        {% if records %}
        <div class="table-responsive">
          <table class="table table-bordered table-hover" id="report-table">
            <thead class="table-light">
              <tr>
                <th>Employee</th>
                <th>Employee Code</th>
                {% if report_type == 'monthly' %}
                <th>Present Days</th>
                <th>Working Days</th>
                <th>Paid Leaves</th>
                <th>Weekend Days</th>
                <th>Festival Days</th>
                <th>Gross Salary</th>
                <th>Deductions</th>
                <th>Net Salary</th>
                <th>Status</th>
                {% else %}
                <th>Months Paid</th>
                <th>Annual Gross</th>
                <th>Annual Deductions</th>
                <th>Annual Net</th>
                <th>Avg Monthly</th>
                {% endif %}
              </tr>
            </thead>
            <tbody>
              {% for record in records %}
              <tr>
                <td>
                  <strong>{{ record.name }}</strong>
                </td>
                <td>{{ record.emp_code ?: record.username }}</td>
                {% if report_type == 'monthly' %}
                <td>{{ record.present_days ?: record.total_attendees ?: 0 }}</td>
                <td>{{ record.working_days ?: record.current_month_days ?: 0 }}</td>
                <td>{{ record.paid_leaves ?: 0 }}</td>
                <td>{{ record.total_weekends ?: record.Total_Weekends ?: 0 }}</td>
                <td>{{ record.festival_holidays ?: record.total_festivals ?: 0 }}</td>
                <td class="text-end">${{ "%.2f"|format(record.gross_salary ?: record.monthly_ctc ?: 0) }}</td>
                <td class="text-end text-danger">${{ "%.2f"|format(record.deductions ?: record.pf ?: 0) }}</td>
                <td class="text-end"><strong>${{ "%.2f"|format(record.net_salary ?: 0) }}</strong></td>
                <td>
                  {% if record.status == 'Pending' %}
                  <span class="badge bg-warning">Pending</span>
                  {% elseif record.status == 'Paid' %}
                  <span class="badge bg-success">Paid</span>
                  {% elseif record.status == 'Released' %}
                  <span class="badge bg-info">Released</span>
                  {% else %}
                  <span class="badge bg-secondary">{{ record.status }}</span>
                  {% endif %}
                </td>
                {% else %}
                <td>{{ record.months_paid ?: 0 }}</td>
                <td class="text-end">${{ "%.2f"|format(record.annual_gross ?: 0) }}</td>
                <td class="text-end text-danger">${{ "%.2f"|format(record.annual_deductions ?: 0) }}</td>
                <td class="text-end"><strong>${{ "%.2f"|format(record.annual_net ?: 0) }}</strong></td>
                <td class="text-end">${{ "%.2f"|format(record.avg_monthly ?: 0) }}</td>
                {% endif %}
              </tr>
              {% endfor %}
            </tbody>
            <tfoot class="table-secondary">
              <tr>
                <th colspan="{% if report_type == 'monthly' %}7{% else %}2{% endif %}">TOTAL</th>
                {% if report_type == 'monthly' %}
                <th class="text-end">${{ "%.2f"|format(totals.gross_salary ?: 0) }}</th>
                <th class="text-end">${{ "%.2f"|format(totals.deductions ?: 0) }}</th>
                <th class="text-end"><strong>${{ "%.2f"|format(totals.net_salary ?: 0) }}</strong></th>
                <th></th>
                {% else %}
                <th></th>
                <th class="text-end">${{ "%.2f"|format(totals.annual_gross ?: 0) }}</th>
                <th class="text-end">${{ "%.2f"|format(totals.annual_deductions ?: 0) }}</th>
                <th class="text-end"><strong>${{ "%.2f"|format(totals.annual_net ?: 0) }}</strong></th>
                <th class="text-end">${{ "%.2f"|format((totals.annual_net ?: 0) / (totals.employees ?: 1)) }}</th>
                {% endif %}
              </tr>
            </tfoot>
          </table>
        </div>
        {% else %}
        <div class="text-center py-5">
          <i class="fa-solid fa-file-excel fa-3x text-muted mb-3"></i>
          <h4>No Records Found</h4>
          <p class="text-muted">No payroll records found for the selected period.</p>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script type="text/javascript">
$(document).ready(function() {
    // Handle form changes to auto-submit
    $('#report_type').on('change', function() {
        var reportType = $(this).val();
        if (reportType === 'annual') {
            $('#report_month').closest('.col-md-3').hide();
        } else {
            $('#report_month').closest('.col-md-3').show();
        }
    });
    
    // Initialize the form based on current report type
    $('#report_type').trigger('change');
    
    // Add search functionality to the table
    if ($('#report-table').length > 0) {
        // Add search input
        var searchHtml = `
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="text" id="report-search" class="form-control" placeholder="Search employees...">
                    <span class="input-group-text">
                        <i class="fa-solid fa-search"></i>
                    </span>
                </div>
            </div>
            <div class="col-md-6 text-end">
                <button type="button" class="btn btn-success" onclick="exportToCSV()">
                    <i class="fa-solid fa-download"></i> Export CSV
                </button>
            </div>
        </div>
        `;
        
        $('#report-table').before(searchHtml);
        
        // Implement search functionality
        $('#report-search').on('keyup', function() {
            var searchTerm = $(this).val().toLowerCase().trim();
            var visibleCount = 0;
            
            $('#report-table tbody tr').each(function() {
                var rowText = $(this).text().toLowerCase();
                
                if (searchTerm === '' || rowText.indexOf(searchTerm) > -1) {
                    $(this).show();
                    visibleCount++;
                } else {
                    $(this).hide();
                }
            });
        });
    }
});

// Export to CSV function
function exportToCSV() {
    var csv = [];
    var rows = $('#report-table tr:visible');
    
    for (var i = 0; i < rows.length; i++) {
        var row = [], cols = rows[i].querySelectorAll('td, th');
        
        for (var j = 0; j < cols.length; j++) {
            var data = cols[j].innerText.replace(/(\r\n|\n|\r)/gm, '').replace(/(\s\s)/gm, ' ');
            data = data.replace(/"/g, '""');
            row.push('"' + data + '"');
        }
        
        csv.push(row.join(','));
    }
    
    var csvFile = new Blob([csv.join('\n')], { type: 'text/csv' });
    var downloadLink = document.createElement('a');
    
    downloadLink.download = 'payroll_report_{{ year }}_{{ month ?: "annual" }}.csv';
    downloadLink.href = window.URL.createObjectURL(csvFile);
    downloadLink.style.display = 'none';
    
    document.body.appendChild(downloadLink);
    downloadLink.click();
    document.body.removeChild(downloadLink);
}

// Print styles
var printStyles = `
<style type="text/css" media="print">
    @page {
        margin: 0.5in;
        size: A4 landscape;
    }
    
    body * {
        visibility: hidden;
    }
    
    #content, #content * {
        visibility: visible;
    }
    
    .btn, .card-tools, .breadcrumb {
        display: none !important;
    }
    
    .card {
        border: none !important;
        box-shadow: none !important;
    }
    
    .table {
        font-size: 10px !important;
    }
    
    .page-header h1 {
        font-size: 18px !important;
        margin-bottom: 10px !important;
    }
</style>
`;

$('head').append(printStyles);
</script>

{{ footer }}