<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
      	<a type="button" data-toggle="tooltip" title="{{ button_export }}" id="button-export" class="btn btn-warning" style="width:38px; height:38px; padding:6px 0; text-align:center; border-radius:4px;"><i class="fa fa-download"></i></a>
        <button type="submit" id="button-invoice" form="form-poorder" formaction="{{ invoice }}" data-toggle="tooltip" title="{{ button_invoice_print }}" class="btn btn-info" style="width:38px; height:38px; padding:6px 0; text-align:center; border-radius:4px;"><i class="fa fa-print"></i></button>
		<button type="submit" form="form-poorder" formaction="{{ copy }}" data-toggle="tooltip" title="{{ button_copy }}" class="btn btn-default" style="width:38px; height:38px; padding:6px 0; text-align:center; border-radius:4px; background-color: cornflowerblue;"><i class="fa fa-copy"></i></button>
        <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary" style="width:38px; height:38px; padding:6px 0; text-align:center; border-radius:4px;"><i class="fa fa-plus"></i></a>
