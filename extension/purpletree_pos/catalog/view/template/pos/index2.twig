         function autoSaveCartToDefault() {
              var posCart = JSON.parse(localStorage.getItem("pos_cart") || "[]");
              if (!posCart || posCart.length === 0) return; 
              var allHolds = JSON.parse(localStorage.getItem("allcartholddata") || "[]");
              var defaultHoldIndex = allHolds.findIndex(function(h) { return h.description === "Running Cart" || h.description === "Default"; });
              if (defaultHoldIndex !== -1) {
                  allHolds[defaultHoldIndex].cart = posCart;
                  allHolds[defaultHoldIndex].description = "Running Cart";
              } else {
                  allHolds.push({ id: Date.now(), description: "Running Cart", cart: posCart });
              }
              localStorage.setItem("allcartholddata", JSON.stringify(allHolds));
              if (typeof renderHoldCartList === "function") renderHoldCartList();
          }
          function clearAutoSaveBackup() {
              var allHolds = JSON.parse(localStorage.getItem("allcartholddata") || "[]");
              var filtered = allHolds.filter(function(h) { return h.description !== "Running Cart" && h.description !== "Default"; });
              if (filtered.length !== allHolds.length) {
                  localStorage.setItem("allcartholddata", JSON.stringify(filtered));
                  if (typeof renderHoldCartList === "function") renderHoldCartList();
              }
          }
          (function() {
              var originalSetItem = localStorage.setItem;
              localStorage.setItem = function(key, value) {
                  originalSetItem.apply(this, arguments);
                  if (key === 'pos_cart' && typeof autoSaveCartToDefault === 'function') {
                      autoSaveCartToDefault();
                  }
              };
          })();
