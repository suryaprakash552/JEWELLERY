         function updateTotalPayAmountDisplay() {
         	let subtotalText = document.getElementById('yousubtotal')?.textContent || sessionStorage.getItem('subTotal') || '0';
         	let discountText = document.getElementById('yousaveddiscount')?.textContent || sessionStorage.getItem('discount') || '0';
         	let taxText = document.getElementById('yourtotaltax')?.textContent || sessionStorage.getItem('totalTax') || '0';
         	const extractNumber = val => {
         		if (!val) return 0;
         		const n = parseFloat(String(val).replace(/[^0-9.-]+/g, ''));
         		return isNaN(n) ? 0 : n;
         	};
         	let subtotal = extractNumber(subtotalText);
         	let discount = extractNumber(discountText);
         	let tax = extractNumber(taxText);
         	let totalPayAmount = subtotal + tax - discount;
         	const extractCurrency = val => {
         		if (!val) return '';
         		return String(val).replace(/[0-9.,\s-]+/g, '');
         	};
         	let currency = extractCurrency(subtotalText) || extractCurrency(taxText) || '';
         	if (!currency && window.posData && posData.currency_code) currency = posData.currency_code;
         	const el = document.getElementById('totalBeforeRoundOffAmount');
         	if (el) {
         		el.textContent = (currency ? currency + ' ' : '') + totalPayAmount.toFixed(2);
         	}
         }
