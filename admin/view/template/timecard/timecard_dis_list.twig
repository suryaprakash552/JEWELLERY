{{ header }}{{ column_left }}
 <style>
.my-filter-input {
    display: none;
}
.my-filter{
    display: block;    
    padding: 10px;
    margin: 0 0 1px 0;
    cursor: pointer;
    background: #6AAB95;
    border: 1px solid #A7A7A7;
    border-radius: 3px;
    color: #FFF;
    transition: ease .5s;
}

.my-filter:hover {
    background: #4E8774;
}

.my-filter-content {
    background: #313941;
    padding: 5px 0px;
    border: 1px solid #A7A7A7;
    margin: 0 0 2px 0;
    border-radius: 3px;
}

.my-filter-input + .my-filter + .my-filter-content {
    display: none;
    padding-right: -2px;
}

.my-filter-input:checked + .my-filter + .my-filter-content {
    display: block;
}

.myfilter-container
{
    padding-left: 250px;
}
</style>
<div id="content">
  <div class="page-header">
    <div class="container-fluid myfilter-container">
      <div class="float-end">
    <!-- <button type="button" data-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-product').toggleClass('hidden-sm hidden-xs');" class="btn btn-default hidden-md hidden-lg"><i class="fa fa-filter"></i></button>  -->
       <a href="{{ add }}" data-toggle="tooltip" title="{{ button_add }}" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="button" form="form-product" formaction="{{ delete }}" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-product').submit() : false;"><i class="fa-regular fa-trash-can"></i></button>
      </div>
      <h1 style="color:white;">{{ heading_title }}</h1>
      <ol class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}
            <li class="breadcrumb-item"><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ol>
    </div>
  </div>
  <div class="container-fluid myfilter-container">{% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="row">
      <div id="filter-product" class="col-sm-12 hidden-sm hidden-xs">
        <div class="panel panel-default">
        <input class="my-filter-input"type="checkbox" id="title2" />
        <label class='my-filter panel-heading'for="title2" style="background-color:#313941;color:white;"><i class="fa fa-filter"></i> {{ text_filter }}<span style="float:right;"><i class="fa fas fa-chevron-down fa-1x" ></i></span>
        </label>
        <div class="my-filter-content panel-body">
       <p>
           <div class="row mb-2" style="row-gap: 20px;margin-left:150px">
        <div class="col-sm-5">
              <label style="color:white;" class="control-label" for="input-name">{{ entry_name }}</label>
              <input style="color:black;"  type="text" name="filter_packagename" value="{{ filter_packagename }}"  id="input-name" class="form-control" />
            </div>
            <div class="col-sm-5">
              <label style="color:white;" class="control-label" for="input-status">{{ entry_status }}</label>
              <select style="color:black;" name="filter_status" id="input-status" class="form-control">
                <option value=""></option>
                  {% if filter_status == '1' %}
                <option value="1" selected="selected">{{ text_enabled }}</option>
                  {% else %}
                <option value="1">{{ text_enabled }}</option>
                  {% endif %}
                  {% if filter_status == '0' %}
                <option value="0" selected="selected">{{ text_disabled }}</option>
                  {% else %}
                <option value="0">{{ text_disabled }}</option>
                  {% endif %}
              </select>
            </div>
            <div class="form-group" style="margin-left:1200px">
              <button type="button"  style="background-color:white;color:black;" id="button-filter" class="btn btn-default"><i class="fa fa-filter"></i> {{ button_filter }}</button>
            </div>
         </p>
        </div>
        </div>
        </div>
      </div>
      <div class="col-sm-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title" style="color:white"><b><i class="fa fa-list"></i> </b></h3> 
          </div>
          <div class="panel-body">
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-product">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead style="background-color:#861f41;">
                    <tr>
                      <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                      <td class="text-center" style="color:black;">{{ column_srno }}</td>
                     
                      <td class="text-center">{% if sort == 'p.packagename' %} <a style="color:white;" href="{{ sort_name }}" class="{{ order|lower }}">{{ column_name }}</a> {% else %} <a style="color:black;" href="{{ sort_name }}">{{ column_name }}</a> {% endif %}</td>
                      <td class="text-center" style="color:black;">{{ column_price }}</td>
                      <td class="text-center" style="color:black;">{{ column_date }}</td>
                      <td class="text-center">{% if sort == 'p.status' %} <a style="color:black;" href="{{ sort_status }}" class="{{ order|lower }}">{{ column_status }}</a> {% else %} <a style="color:black;" href="{{ sort_status }}">{{ column_status }}</a> {% endif %}</td>
                      <td class="text-center" style="color:black;">{{ column_modified }}</td>
                      <td class="text-center" style="color:black;">{{ column_action }}</td> 
                     </tr>
                  </thead>
                  <tbody>
                  
                  {% if products %}
                  {% for product in products %}
                  <tr>
                    <td class="text-center">{% if product.packageid in selected %}
                      <input type="checkbox" name="selected[]" value="{{ product.packageid }}" checked="checked" />
                      {% else %}
                      <input type="checkbox" name="selected[]" value="{{ product.packageid }}" />
                      {% endif %}</td>
                    <td class="text-left">{{ product.srno }}</td>
                       
                    <td class="text-left">{{ product.packagename }}</td>
                    <td class="text-left">{{ product.price }}</td>
                    <td class="text-left">{{ product.creationdate }}</td>
                    <td class="text-left">{{ product.status }}</td>
                    <td class="text-left">{{ product.modifiedby }}</td>
                    <td class="text-left"><a href="{{ product.edit }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary"><i class="fa fa-pencil"></i></a></td>
                    </tr>
                  {% endfor %}
                  {% else %}
                  <tr>
                    <td class="text-center" colspan="11">{{ text_no_results }}</td>
                  </tr>
                  {% endif %}
                    </tbody>
                  
                </table>
              </div>
            </form>
            <div class="row">
              <div class="col-sm-6 text-left" >{{ pagination }}</div>
              <div class="col-sm-6 text-right"style="color:white">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script type="text/javascript"><!--
$('#button-filter').on('click', function() {
	var url = '';

	var filter_packagename = $('input[name=\'filter_packagename\']').val();

	if (filter_packagename) {
		url += '&filter_packagename=' + encodeURIComponent(filter_packagename);
	}

	var filter_status = $('select[name=\'filter_status\']').val();

	if (filter_status !== '') {
		url += '&filter_status=' + encodeURIComponent(filter_status);
	}

	location = 'index.php?route=preconfig/finoaepscomm&user_token={{ user_token }}' + url;
});
//--></script> 
  <script type="text/javascript"><!--
// IE and Edge fix!
$('button[form=\'form-product\']').on('click', function(e) {
	$('#form-product').attr('action', $(this).attr('formaction'));
});
  
$('input[name=\'filter_packagename\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=preconfig/finoaepscomm/autocomplete&user_token={{ user_token }}&filter_packagename=' +  encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['packagename'],
						value: item['packageid']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_packagename\']').val(item['label']);
	}
});

//--></script></div>
{{ footer }} 