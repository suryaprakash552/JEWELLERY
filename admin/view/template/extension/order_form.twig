	html += '</td>';
	html += '<td>';
	html += '	<select name="po_custom_total['+ po_custom_total_row +'][type]" class="form-control">';
	html += '		<option value="1">{{ text_discount }}</option>';
	html += '		<option value="0">{{ text_fee }}</option>';
	html += '	</select>';
	html += '</td>';
	html += '<td>';
	html += '	<select name="po_custom_total['+ po_custom_total_row +'][dtype]" class="form-control">';
	html += '		<option value="P">{{ text_percent }}</option>';
	html += '		<option value="F">{{ text_total_amount }}</option>';
	html += '	</select>';
	html += '</td>';
	html += '<td>';
	html += '	<input type="text" name="po_custom_total['+ po_custom_total_row +'][amt]" value="" id="input-po_custom_total_amt'+ po_custom_total_row +'" class="form-control" placeholder="{{ text_amount }}" />';
	html += '</td>';
	html += '<td class="text-right">';
	html += '	<button type="button" data-toggle="tooltip" title="{{ button_add }}" data-loading-text="{{ text_loading }}" class="btn btn-primary" onclick="loadcustomtotal();"><i class="fa fa-plus-circle"></i></button>';
	html += '	<button type="button" data-toggle="tooltip" title="{{ button_remove }}" data-loading-text="{{ text_loading }}" class="btn btn-danger" onclick="removecustomototal('+ po_custom_total_row +')"><i class="fa fa-minus-circle"></i></button>';
	html += '</td>';
	html += '</tr>';
	
	$('#custom-totals').append(html);
	
	po_custom_total_row++;
}

function removecustomototal(row){
	$.ajax({
		url: 'index.php?route=extension/me_purchase_order.me_removecustomtotal&user_token={{ user_token }}&row='+row,
		type: 'post',
		data: $('#custom-totals select, #custom-totals input'),
		dataType: 'json',
		crossDomain: true,
		beforeSend: function() {
			
		},
		complete: function() {
			
		},
		success: function(json) {
			$('.alert-dismissible, .text-danger, .text-success').remove();
			$('#custom-total-'+ row).remove();
			$('#input-custom_total_amt').val('');
			$('#input-custom_total_title').val('');
			if(json['success']){
				totals();
			}
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
}
