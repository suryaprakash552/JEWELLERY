<script>
// --- Helpers to read/write the bottom total rows ---------------------------
function parseMoney(str) {
  if (!str) return 0;
  // Remove currency symbol, commas, spaces
  var n = String(str).replace(/[^\d.-]/g, '');
  var v = parseFloat(n);
  return isNaN(v) ? 0 : v;
}

function findRowByLabel(label) {
  // finds the <tr> whose first <td> contains "<label>:"
  var match = null;
  $('#total tr').each(function () {
    var txt = ($(this).find('td:first').text() || '').trim();
    if (txt.toLowerCase().indexOf(label.toLowerCase() + ':') === 0) {
      match = $(this);
      return false;
    }
  });
  return match;
}

function getAmountFromRow(label) {
  var $row = findRowByLabel(label);
  if (!$row) return 0;
  var amtText = $row.find('td:last').text();
  return parseMoney(amtText);
}

function setAmountToRow(label, amount) {
  var $row = findRowByLabel(label);
  if ($row) {
    $row.find('td:last').html('₹' + amount.toFixed(2));
  } else {
    // If the row doesn't exist yet, append a minimal one
    $('#total').append(
      '<tr style="border:none!important;">' +
      '<td class="text-end" colspan="4" style="background-color:unset;border:none!important;padding:8px;"><b>' + label + ':</b></td>' +
      '<td class="text-end" width="20%" style="background-color:unset;border:none!important;padding:8px;"><strong>₹' + amount.toFixed(2) + '</strong></td>' +
      '</tr>'
    );
  }
}

// --- Instant recalc of Sub Total and Total (no server round-trip) ----------
function recalcTotalsUI() {
  var subtotal = 0;

  // Sum price * qty from the current inputs on the table
  $('#cart tr').each(function () {
    var price = parseFloat($(this).find('input[name$="[price]"]').val());
    var qty   = parseFloat($(this).find('input[name$="[quantity]"]').val());
    if (!isNaN(price) && !isNaN(qty)) subtotal += price * qty;
  });

  // Keep using currently displayed figures for the other rows
  var tax      = getAmountFromRow('Tax');       // 0.00 if not present
  var shipping = getAmountFromRow('Shipping');  // 0.00 if not present
  var balance  = getAmountFromRow('Balance');   // 0.00 if not present

  // Update Sub Total and Total rows instantly
  setAmountToRow('Sub Total', subtotal);
  setAmountToRow('Total', subtotal + tax + shipping + balance);
}

// --- Patch your existing row-total updater to call the UI recalc -----------
var _origUpdateRowTotal = window.updateRowTotal;
window.updateRowTotal = function (row) {
  // Keep your original behavior (updates the green per-row total text)
  if (typeof _origUpdateRowTotal === 'function') {
    _origUpdateRowTotal(row); // uses your existing logic
  } else {
    // Fallback if function name changed in future
    var price = parseFloat($('input[name="product[' + row + '][price]"]').val()) || 0;
    var qty   = parseInt($('input[name="product[' + row + '][quantity]"]').val()) || 1;
    $('.product-total[data-row="' + row + '"]').text('₹' + (price * qty).toFixed(2));
  }

  // Instantly recalc bottom totals in the UI
  recalcTotalsUI();
};

// --- Also recalc when user types in price/qty (covers all dynamic rows) ---
$(document).on('input change',
  '#cart input[name$="[price]"], #cart input[name$="[quantity]"]',
  function () {
    var name = $(this).attr('name') || '';
    var m = name.match(/product\[(\d+)\]\[(?:price|quantity)\]/);
    if (m) {
      window.updateRowTotal(m[1]);
    } else {
      // If we can't detect the row index, still update the bottom totals
      recalcTotalsUI();
    }
  }
);

// Optional: after any successful AJAX refresh of products/totals,
// run one more recalc to sync the displayed numbers immediately.
document.addEventListener('products:refreshed', function(){ recalcTotalsUI(); });
</script>

