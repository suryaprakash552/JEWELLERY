{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="float-end">
        {#<button type="button" id="button-bulk-approve" data-bs-toggle="tooltip" title="Approve Selected" class="btn btn-success" disabled style="background-color:black">#}
        {#  <i class="fa-solid fa-check"></i> Approve Selected#}
        {#</button>#}
        {#<button type="button" id="button-bulk-reject" data-bs-toggle="tooltip" title="Reject Selected" class="btn btn-danger" disabled style="background-color:black">#}
        {#  <i class="fa-solid fa-times"></i> Reject Selected#}
        {#</button>#}
        {#<a href="{{ export_url }}" data-bs-toggle="tooltip" title="Export to CSV" class="btn btn-info" style="background-color:black">#}
        {#  <i class="fa-solid fa-download"></i> Export#}
        {#</a>#}
      </div>
      <h1 style="color:white">Admin Leave Management</h1>
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="{{ home_url }}">Home</a></li>
        <li class="breadcrumb-item active">Leave Management</li>
      </ol>
    </div>
  </div>

  <div class="container-fluid">
    <!-- Alert Messages -->
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible">
      <i class="fa-solid fa-circle-exclamation"></i> {{ error_warning }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    {% if success %}
    <div class="alert alert-success alert-dismissible">
      <i class="fa-solid fa-circle-check"></i> {{ success }}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
    {% endif %}

    <!-- Statistics Cards -->
    <div class="row mb-4">
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card text-white bg-warning">
          <div class="card-body" style="background-color:black">
            <div class="d-flex justify-content-between">
              <div>
                <h3>{{ stats.pending ?? 0 }}</h3>
                <p class="mb-0">Pending Requests</p>
              </div>
              <div class="align-self-center">
                <i class="fa-solid fa-clock fa-2x"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card text-white bg-success">
          <div class="card-body" style="background-color:black">
            <div class="d-flex justify-content-between">
              <div>
                <h3>{{ stats.approved ?? 0 }}</h3>
                <p class="mb-0">Approved</p>
              </div>
              <div class="align-self-center">
                <i class="fa-solid fa-check fa-2x"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card text-white bg-danger">
          <div class="card-body"style="background-color:black">
            <div class="d-flex justify-content-between">
              <div>
                <h3>{{ stats.rejected ?? 0 }}</h3>
                <p class="mb-0">Rejected</p>
              </div>
              <div class="align-self-center">
                <i class="fa-solid fa-times fa-2x"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="col-lg-3 col-md-6 mb-3">
        <div class="card text-white bg-info">
          <div class="card-body"style="background-color:black">
            <div class="d-flex justify-content-between">
              <div>
                <h3>{{ stats.total ?? 0 }}</h3>
                <p class="mb-0">Total Requests</p>
              </div>
              <div class="align-self-center">
                <i class="fa-solid fa-list fa-2x"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <div class="card mb-4">
      <div class="card-header">
        <i class="fa-solid fa-filter"></i> Filters
      </div>
      <div class="card-body">
        <form method="get" id="filter-form">
          <input type="hidden" name="route" value="leavemanagement/adminleavemanagement">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="row">
            <div class="col-lg-2 col-md-6 mb-3">
              <label for="filter-date-from" class="form-label">Date From</label>
              <input type="date" name="filter_date_from" value="{{ filter_date_from }}" 
                     id="filter-date-from" class="form-control">
            </div>
            <div class="col-lg-2 col-md-6 mb-3">
              <label for="filter-date-to" class="form-label">Date To</label>
              <input type="date" name="filter_date_to" value="{{ filter_date_to }}" 
                     id="filter-date-to" class="form-control">
            </div>
            <div class="col-lg-3 col-md-6 mb-3">
              <label for="filter-employee" class="form-label">Employee</label>
              <input type="text" name="filter_employee" value="{{ filter_employee }}" 
                     placeholder="Search by name or ID" id="filter-employee" class="form-control">
            </div>
            <div class="col-lg-2 col-md-6 mb-3">
              <label for="filter-leave-type" class="form-label">Leave Type</label>
              <select name="filter_leave_type" id="filter-leave-type" class="form-select"style="width:100%;">
                <option value="">All Types</option>
                {% for key, type in leave_types %}
                <option value="{{ key }}" {% if filter_leave_type == key %}selected{% endif %}>{{ type }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-lg-2 col-md-6 mb-3">
              <label for="filter-status" class="form-label">Status</label>
              <select name="filter_status" id="filter-status" class="form-select"style="width:100%;">>
                <option value="">All Status</option>
                {% for key, status in status_options %}
                <option value="{{ key }}" {% if filter_status == key %}selected{% endif %}>{{ status }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="col-lg-1 col-md-6 mb-3">
              <label class="form-label">&nbsp;</label>
              <div>
                <button type="submit" class="btn btn-primary">
                  <i class="fa-solid fa-search"></i>
                </button>
                {#<button type="button" class="btn btn-secondary" onclick="clearFilters()">#}
                {#  <i class="fa-solid fa-refresh"></i>#}
                {#</button>#}
              </div>
            </div>
          </div>
        </form>
      </div>
    </div>

    <!-- Leave Requests Table -->
    <div class="card">
      <div class="card-header">
        <i class="fa-solid fa-list"></i> Leave Requests
      </div>
      <div class="card-body" >
        <form id="bulk-form" method="post" action="{{ bulk_url }}">
          <input type="hidden" name="user_token" value="{{ user_token }}">
          <div class="table-responsive">
            <table class="table table-bordered table-hover black-table">
              <thead>
                <tr>
                  <th width="1">
                    <input type="checkbox" id="select-all">
                  </th>
                  <th>Employee</th>
                  <th>Leave Type</th>
                  <th>Start Date</th>
                  <th>End Date</th>
                  <th>Days</th>
                  <th>Status</th>
                  <th>Applied On</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody style="background-color: black; color: white;">
                {% if leaves %}
                {% for leave in leaves %}
                <tr style="background-color: black; color: white;">
                  <td>
                    {% if leave.status == '0' %}
                    <input type="checkbox" name="selected[]" value="{{ leave.id }}" class="leave-checkbox">
                    {% endif %}
                  </td>
                  <td>
                    <strong>{{ leave.employee_name }}</strong><br>
                    <small class="text-muted">ID: {{ leave.employee_id }}</small>
                  </td>
                  <td class="text-capitalize">{{ leave_types[leave.leave_type] ?? leave.leave_type }}</td>
                  <td>{{ leave.formatted_start_date }}</td>
                  <td>{{ leave.formatted_end_date }}</td>
                  <td>{{ leave.total_days }}</td>
                  <td>
                    {% set status_classes = {'0': 'warning', '1': 'success', '2': 'danger', '3': 'secondary'} %}
                    {% set class = status_classes[leave.status] ?? 'secondary' %}
                    <span class="badge bg-{{ class }}">{{ leave.status_text }}</span>
                  </td>
                  <td>{{ leave.formatted_created_at }}</td>
                  <td>
                    {#<div class="btn-group btn-group-sm">#}
                    {#  <a href="{{ view_url }}&leave_id={{ leave.id }}" #}
                    {#     class="btn btn-info" title="View Details">#}
                    {#    <i class="fa-solid fa-eye"></i>#}
                    {#  </a>#}
                      {% if leave.status == '0' %}
                      <button type="button" class="btn btn-success" 
                              onclick="approveLeave({{ leave.id }})" title="Approve">
                        <i class="fa-solid fa-check"></i>
                      </button>
                      <button type="button" class="btn btn-danger" 
                              onclick="showRejectModal({{ leave.id }})" title="Reject">
                        <i class="fa-solid fa-times"></i>
                      </button>
                      {% endif %}
                    </div>
                  </td>
                </tr>
                {% endfor %}
                {% else %}
                <tr style="background-color: black; color: white;">
                  <td colspan="9" class="text-center">No leave requests found.</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="rejectModalLabel">Reject Leave Request</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="reject-form" method="post">
        <div class="modal-body">
          <div class="mb-3">
            <label for="rejection-reason" class="form-label">Reason for Rejection:</label>
            <textarea name="rejection_reason" id="rejection-reason" class="form-control" rows="4" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">
            <i class="fa-solid fa-times"></i> Reject Leave
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script type="text/javascript"><!--
$(document).ready(function() {
    // Select all checkbox functionality
    $('#select-all').on('change', function() {
        $('.leave-checkbox').prop('checked', $(this).prop('checked'));
        toggleBulkButtons();
    });
    
    $('.leave-checkbox').on('change', function() {
        var total = $('.leave-checkbox').length;
        var checked = $('.leave-checkbox:checked').length;
        $('#select-all').prop('checked', total === checked);
        toggleBulkButtons();
    });
    
    // Bulk action buttons
    $('#button-bulk-approve').on('click', function() {
        if (confirm('Are you sure you want to approve selected leave requests?')) {
            $('#bulk-form').append('<input type="hidden" name="action" value="approve">').submit();
        }
    });
    
    $('#button-bulk-reject').on('click', function() {
        if (confirm('Are you sure you want to reject selected leave requests?')) {
            $('#bulk-form').append('<input type="hidden" name="action" value="reject">').submit();
        }
    });
    
    // Reject form
    $('#reject-form').on('submit', function(e) {
        e.preventDefault();
        var leaveId = $(this).data('leave-id');
        var reason = $('#rejection-reason').val();
        
        if (reason.trim() === '') {
            alert('Please provide a reason for rejection.');
            return;
        }
        
        var url = '{{ reject_url }}&leave_id=' + leaveId;
        $(this).attr('action', url).off('submit').submit();
    });
});

function toggleBulkButtons() {
    var checked = $('.leave-checkbox:checked').length;
    $('#button-bulk-approve, #button-bulk-reject').prop('disabled', checked === 0);
}

function approveLeave(leaveId) {
    if (confirm('{{ text_confirm_approve }}')) {
        window.location.href = '{{ approve_url }}&leave_id=' + leaveId;
    }
}

function showRejectModal(leaveId) {
    $('#reject-form').data('leave-id', leaveId);
    $('#rejection-reason').val('');
    $('#rejectModal').modal('show');
}

function clearFilters() {
    window.location.href = '{{ base_url }}';
}

// Auto-refresh pending requests every 5 minutes
setInterval(function() {
    if ($('.table-warning').length > 0) {
        location.reload();
    }
}, 300000);
//--></script>

{{ footer }}