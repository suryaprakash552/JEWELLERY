  <script type="text/javascript"><!--
  var attribute_row = {{ attribute_row }};

  function addAttribute() {
	  html = '<tr id="attribute-row' + attribute_row + '">';
	  html += '  <td class="text-left" style="width: 20%;"><input type="text" name="product_attribute[' + attribute_row + '][name]" value="" placeholder="{{ entry_attribute }}" class="form-control" /><input type="hidden" name="product_attribute[' + attribute_row + '][attribute_id]" value="" /></td>';
	  html += '  <td class="text-left">';
    {% for language in languages %}
	  html += '<div class="input-group"><span class="input-group-addon"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /></span><textarea name="product_attribute[' + attribute_row + '][product_attribute_description][{{ language.language_id }}][text]" rows="5" placeholder="{{ entry_text }}" class="form-control"></textarea></div>';
    {% endfor %}
	  html += '  </td>';
	  html += '  <td class="text-right"><button type="button" onclick="$(\'#attribute-row' + attribute_row + '\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
	  html += '</tr>';

	  $('#attribute tbody').append(html);

	  attributeautocomplete(attribute_row);

	  attribute_row++;
  }

  function attributeautocomplete(attribute_row) {
	  $('input[name=\'product_attribute[' + attribute_row + '][name]\']').autocomplete({
		  'source': function(request, response) {
			  $.ajax({
				  url: 'index.php?route=catalog/attribute/autocomplete&user_token={{ user_token }}&filter_name=' + encodeURIComponent(request),
				  dataType: 'json',
				  success: function(json) {
					  response($.map(json, function(item) {
						  return {
							  category: item.attribute_group,
							  label: item.name,
							  value: item.attribute_id
						  }
					  }));
				  }
			  });
		  },
		  'select': function(item) {
			  $('input[name=\'product_attribute[' + attribute_row + '][name]\']').val(item['label']);
			  $('input[name=\'product_attribute[' + attribute_row + '][attribute_id]\']').val(item['value']);
		  }
	  });
  }

  $('#attribute tbody tr').each(function(index, element) {
	  attributeautocomplete(index);
  });
  //--></script>
  
    <script type="text/javascript"><!--
$('#button-filter').on('click', function() {
	var url = '';
    
    var filter_fdate = $('input[name=\'filter_fdate\']').val();

	if (filter_fdate) {
		url += '&filter_fdate=' + encodeURIComponent(filter_fdate);
	}
	
	var filter_tdate = $('input[name=\'filter_tdate\']').val();

	if (filter_tdate) {
		url += '&filter_tdate=' + encodeURIComponent(filter_tdate);
	}

	var filter_status = $('select[name=\'filter_status\']').val();

	if (filter_status !== '') {
		url += '&filter_status=' + encodeURIComponent(filter_status);
	}

	location = 'index.php?route=timecard/timecard&user_token={{ user_token }}' + url;
});
//--></script> 

 
  <script>
document.addEventListener("input", function(e) {
  if (e.target.classList.contains("hours-input")) {
    let value = parseInt(e.target.value, 10);
    let msg = e.target.parentElement.querySelector("small");

    if (isNaN(value)) {
      msg.classList.add("d-none");
      return;
    }

    if (value < 4 || value > 12) {
      msg.classList.remove("d-none"); // show error inside box
    } else {
      msg.classList.add("d-none"); // hide error if valid
    }
  }
});
</script>

<script>
    $(document).on('change', '.work-from-home', function() {
    let row = $(this).data('row');
    let button = $('#button-upload-' + row);

    if ($(this).is(':checked')) {
        button.prop('disabled', false);  // enable upload
    } else {
        button.prop('disabled', true);   // disable upload
    }
})
$(document).on('click', '.upload-btn', function(e) {
    e.preventDefault(); // ⛔ stop form submission
    let row = $(this).attr('id').split('-').pop();
    $('#file-input-' + row).click(); // trigger hidden file input
});
</script>
  <script type="text/javascript"><!--
  var timecard_row = {{ timecard_row }};

  function addtimecard() {
// Get today's date
const baseDate = new Date();

// Offset the date by timecard_row days
const offsetDate = new Date(baseDate);
offsetDate.setDate(baseDate.getDate() + timecard_row);

// Format date as YYYY-MM-DD
const formattedDate = offsetDate.toISOString().split('T')[0];
timecard_row = document.getElementById('timecardrowNumber').value;
    
	  html = '<tr id="timecard-row' + timecard_row + '">';
html += '  <td class="text-right"><input type="date" name="timecard[' + timecard_row + '][date]" value="' + formattedDate + '" class="form-control"/></td>';
html += '  <td class="text-left"><select name="timecard[' + timecard_row + '][projectid]" class="form-control">';
                    {% for project in projects %}
                	  html += '<option value="{{ project.projectid }}">{{ project.projectname }}</option>';
                    {% endfor %}
                	  html += '  </select>';
     html += '  </td>';

     html += '  <td class="text-left"><select name="timecard[' + timecard_row + '][taskid]" class="form-control">'; 
                    {% for task in tasks %}
                	  html += '<option value="{{ task.taskid }}">{{ task.taskname }}</option>';
                    {% endfor %}
                	  html += '  </select>';
     html += '  </td>';
html += '  <td class="text-right">' +
    '<input type="text" name="timecard['+ timecard_row +'][description]" ' +
    'value="" ' +   
    'placeholder="Enter Description" ' +
    'class="form-control"/>' +
    '</td>';
    html += '  <td class="text-right" align="center">' +
    '    <input type="checkbox" name="timecard['+ timecard_row +'][work_from_home]" ' +
    '      value="'+ timecard_row +'" ' +
    '      class="form-check-input work-from-home" ' +
    '      style="width:20px;height:20px" ' +
    '      data-row="'+ timecard_row +'">' +
    '  </td>';           
 html += '  <td class="text-right">' +
    '    <input type="file" name="timecard['+ timecard_row +']" id="file-input-'+ timecard_row +'" class="d-none file-input">' +
    '    <button type="button" ' +
    '      id="button-upload-'+ timecard_row +'" ' +
    '      data-bs-toggle="tooltip" ' +
    '      title="{{ button_upload }}" ' +
    '      class="btn btn-primary upload-btn" ' +
    '      disabled>' + 
    '      <i class="fa-solid fa-upload"></i>' +
    '    </button>' +
    '  </td>';
      html += ' <td class="text-right">';
      html += '   <div>';
        html += ' <input type="number" name="timecard['+ timecard_row +'][hours_spent]" id="hours_spent_'+ timecard_row +'" value="9" min="4" max="12" placeholder="Enter hours (4–12)" class="form-control hours-input"/>';
       html += '  <small class="text-danger d-none">Hours must be between 4 and 12</small>';
     html += '  </div>';
    html += ' </td>';
      html += '  <td class="text-right"><input type="text" disabled name="timecard['+ timecard_row +'][approvedby]" value="" placeholder="{{ entry_approvedby }}" class="form-control"/></td>';
      html += '  <td class="text-right"><input type="text" name="timecard['+ timecard_row +'][status]" disabled value="OPEN" placeholder="{{ entry_status }}" class="form-control"/></td>';
        html += '  <td class="text-left"><button type="button" onclick="$(\'#timecard-row'+ timecard_row +'\').remove();" data-toggle="tooltip" title="{{ button_remove }}" class="btn btn-danger"><i class="fa fa-minus-circle"></i></button></td>';
	  
	  html += '</tr>';

	  $('#discount tbody').append(html);

	  timecard_row++;
	  document.getElementById('timecardrowNumber').value=timecard_row;
  }

  //--></script>
  
