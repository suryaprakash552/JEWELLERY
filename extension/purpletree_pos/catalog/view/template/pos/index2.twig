        async function connectDQ12() {
          try {
            const options = {
              baudRate: 115200,
              dataBits: 8,
              stopBits: 1,
              parity: "none",
            };
            const vendorNames = {
              "0x0483": "STM32",
              "0x0403": "FTDI",
              "0x10C4": "Silicon Labs CP210x",
              "0x067B": "Prolific",
              "0x1A86": "QinHeng CH340",
              "0x16C0": "VOTI",
            };
            const ports = await navigator.serial.getPorts();
            let targetPort;
            if (ports.length > 0) {
              targetPort = ports[0];
            } else {
              const filters = [
                { usbVendorId: 0x0483 },
                { usbVendorId: 0x0403 },
                { usbVendorId: 0x10c4 },
                { usbVendorId: 0x067b },
                { usbVendorId: 0x1a86 },
                { usbVendorId: 0x16c0 },
              ];
              try {
                targetPort = await navigator.serial.requestPort({ filters });
              } catch (error) {
                targetPort = await navigator.serial.requestPort();
              }
