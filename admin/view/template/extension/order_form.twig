  <script type="text/javascript"><!--
    // ========================================
    // PRODUCT AUTOCOMPLETE - SUPPLIER BASED
    // ========================================
    $('input[name="product"]').autocomplete({
    source: function(request, response) {
        var supplier_id = $('input[name="supplier_id"]').val();
        
        console.log('Product search - Supplier ID:', supplier_id);
        console.log('Search term:', request.term);
        
        // Check if supplier is selected
        if (!supplier_id || supplier_id == '' || supplier_id == '0') {
            alert('Please select a supplier first');
            $('input[name="product"]').val('');
            response([]);
            return false;
        }
        
        $.ajax({
            url: 'index.php?route=extension/me_purchase_order.pautocomplete&user_token={{ user_token }}',
            type: 'get',
            data: {
                filter_name: request.term,
                supplier_id: supplier_id
            },
            dataType: 'json',
            success: function(json) {
                console.log('Products response:', json);
                
                if (json && json['products'] && json['products'].length > 0) {
                    response($.map(json['products'], function(item) {
                        return {
                            label: item.name + (item.model ? ' [' + item.model + ']' : '') + ' - Stock: ' + item.quantity,
                            value: item.name,
                            product_id: item.product_id,
                            name: item.name,
                            model: item.model,
                            sku: item.sku,
                            quantity: item.quantity,
                            price: item.price,
                            sale_price: item.sale_price,
                            image: item.image,
                            option: item.option || []
                        };
                    }));
                } else {
                    response([{
                        label: 'No products found for this supplier',
                        value: ''
                    }]);
                }
            },
            error: function(xhr, status, error) {
                console.error('Error:', status, error);
                console.error('Response:', xhr.responseText);
                response([]);
            }
        });
    },
    minLength: 1,
    select: function(event, ui) {
        if (!ui.item.product_id) {
            return false;
        }
        
        console.log('Selected product:', ui.item);

        // Set basic fields
        $('input[name="product"]').val(ui.item.name);
        $('input[name="product_id"]').val(ui.item.product_id);
        $('input[name="stock"]').val(ui.item.quantity);
        
        // Product image
        if (ui.item.image && $('#pimage').length) {
            $('#pimage').html('<img src="'+ui.item.image+'" class="img-fluid mb-3" style="max-width: 200px;">');
        } else if ($('#pimage').length) {
            $('#pimage').html('');
        }

        // Product options - COMPLETE VERSION
        var html = '';
        if (ui.item.option && ui.item.option.length > 0) {
            console.log('Processing options:', ui.item.option);
            
            for (var j = 0; j < ui.item.option.length; j++) {
                var opt = ui.item.option[j];
                console.log('Option type:', opt.type, 'Option data:', opt);
                
                // SELECT DROPDOWN
                if (opt.type === 'select') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">' + opt.name + '</label>';
                    html += '<div class="col-sm-9">';
                    html += '<select name="option['+opt.product_option_id+']" id="input-option-'+opt.product_option_id+'" class="form-select">';
                    html += '<option value="">--- Please Select ---</option>';
                    
                    if (opt.product_option_value_id && opt.product_option_value_id.length > 0) {
                        for (var k = 0; k < opt.product_option_value_id.length; k++) {
                            var val = opt.product_option_value_id[k];
                            html += '<option value="'+val.product_option_value_id+'">';
                            html += val.name;
                            if(val.price && val.price !== '0.00' && val.price !== '0.0000' && val.price !== false) {
                                html += ' (' + val.price_prefix + val.price + ')';
                            }
                            html += '</option>';
                        }
                    }
                    html += '</select>';
                    html += '</div>';
                    html += '</div>';
                }
                
                // RADIO BUTTONS
                if(opt.type === 'radio') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">'+opt.name+'</label>';
                    html += '<div class="col-sm-9">';
                    
                    if (opt.product_option_value_id && opt.product_option_value_id.length > 0) {
                        for (var k = 0; k < opt.product_option_value_id.length; k++) {
                            var val = opt.product_option_value_id[k];
                            html += '<div class="form-check">';
                            html += '<input class="form-check-input" type="radio" name="option['+opt.product_option_id+']" ';
                            html += 'value="'+val.product_option_value_id+'" ';
                            html += 'id="opt-radio-'+opt.product_option_id+'-'+val.product_option_value_id+'"';
                            if(k === 0 && !opt.required) html += ''; // Don't auto-select if not required
                            html += '>';
                            html += '<label class="form-check-label" for="opt-radio-'+opt.product_option_id+'-'+val.product_option_value_id+'">';
                            html += val.name;
                            if(val.price && val.price !== '0.00' && val.price !== '0.0000' && val.price !== false) {
                                html += ' ('+val.price_prefix+val.price+')';
                            }
                            html += '</label>';
                            html += '</div>';
                        }
                    }
                    html += '</div>';
                    html += '</div>';
                }
                
                // CHECKBOXES
                if(opt.type === 'checkbox') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">'+opt.name+'</label>';
                    html += '<div class="col-sm-9">';
                    
                    if (opt.product_option_value_id && opt.product_option_value_id.length > 0) {
                        for (var k = 0; k < opt.product_option_value_id.length; k++) {
                            var val = opt.product_option_value_id[k];
                            html += '<div class="form-check">';
                            html += '<input class="form-check-input" type="checkbox" name="option['+opt.product_option_id+'][]" ';
                            html += 'value="'+val.product_option_value_id+'" ';
                            html += 'id="opt-checkbox-'+opt.product_option_id+'-'+val.product_option_value_id+'">';
                            html += '<label class="form-check-label" for="opt-checkbox-'+opt.product_option_id+'-'+val.product_option_value_id+'">';
                            html += val.name;
                            if(val.price && val.price !== '0.00' && val.price !== '0.0000' && val.price !== false) {
                                html += ' ('+val.price_prefix+val.price+')';
                            }
                            html += '</label>';
                            html += '</div>';
                        }
                    }
                    html += '</div>';
                    html += '</div>';
                }
                
                // TEXT INPUT
                if(opt.type === 'text') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">' + opt.name + '</label>';
                    html += '<div class="col-sm-9">';
                    html += '<input type="text" name="option['+opt.product_option_id+']" id="input-option-'+opt.product_option_id+'" class="form-control" placeholder="'+opt.name+'">';
                    html += '</div>';
                    html += '</div>';
                }
                
                // TEXTAREA
                if(opt.type === 'textarea') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">' + opt.name + '</label>';
                    html += '<div class="col-sm-9">';
                    html += '<textarea name="option['+opt.product_option_id+']" id="input-option-'+opt.product_option_id+'" class="form-control" rows="3" placeholder="'+opt.name+'"></textarea>';
                    html += '</div>';
                    html += '</div>';
                }
                
                // DATE
                if(opt.type === 'date') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">' + opt.name + '</label>';
                    html += '<div class="col-sm-9">';
                    html += '<input type="text" name="option['+opt.product_option_id+']" id="input-option-'+opt.product_option_id+'" class="form-control datepicker-option" placeholder="'+opt.name+'">';
                    html += '</div>';
                    html += '</div>';
                }
                
                // DATETIME
                if(opt.type === 'datetime') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">' + opt.name + '</label>';
                    html += '<div class="col-sm-9">';
                    html += '<input type="text" name="option['+opt.product_option_id+']" id="input-option-'+opt.product_option_id+'" class="form-control datetime-option" placeholder="'+opt.name+'">';
                    html += '</div>';
                    html += '</div>';
                }
                
                // TIME
                if(opt.type === 'time') {
                    html += '<div class="mb-3 row">';
                    html += '<label class="col-sm-3 col-form-label' + (opt.required ? ' required' : '') + '">' + opt.name + '</label>';
                    html += '<div class="col-sm-9">';
                    html += '<input type="text" name="option['+opt.product_option_id+']" id="input-option-'+opt.product_option_id+'" class="form-control time-option" placeholder="'+opt.name+'">';
                    html += '</div>';
                    html += '</div>';
                }
            }
        }
        
        $('#option').html(html);
        console.log('Options HTML generated');

        // Initialize datetimepickers for date/time options
        if ($.fn.datetimepicker) {
            setTimeout(function() {
                $('#option .datepicker-option').datetimepicker({
                    format: 'Y-m-d',
                    timepicker: false,
                    scrollMonth: false,
                    scrollInput: false
                });
                $('#option .datetime-option').datetimepicker({
                    format: 'Y-m-d H:i:s',
                    timepicker: true,
                    scrollMonth: false,
                    scrollInput: false
                });
                $('#option .time-option').datetimepicker({
                    format: 'H:i:s',
                    datepicker: false,
                    scrollMonth: false,
                    scrollInput: false
                });
            }, 100);
        }
        
        return false;
    }
 });
    
