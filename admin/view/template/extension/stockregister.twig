{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
      <div style="margin-left: 37px;">
        <h1> Stock Register</h1>
         <ol class="breadcrumb">
            {% for breadcrumb in breadcrumbs %}
            <li class="breadcrumb-item">
              <a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a>
            </li>
            {% endfor %}
          </ol>
      </div>
      {#<div>#}
      {#  <button type="button" class="btn btn-success" onclick="exportData()" style="background: #10b981; border: none; padding: 10px 20px; border-radius: 6px;">#}
      {#    <i class="fa fa-download"></i> Export CSV#}
      {#  </button>#}
      {#</div>#}
    </div>
  </div>

  <div class="container-fluid" style="padding: 3px 30px;">
    {% if success %}
      <div class="alert alert-success alert-dismissible" style="background: #10b981; color: #fff; border: none; border-radius: 6px;">
        <i class="fa fa-check-circle"></i> {{ success }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endif %}
    
    {% if error %}
      <div class="alert alert-danger alert-dismissible" style="background: #ef4444; color: #fff; border: none; border-radius: 6px;">
        <i class="fa fa-exclamation-circle"></i> {{ error }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    {% endif %}
<style>
input::placeholder {
  color: #fff !important;
  opacity: 1; /* for Firefox */
}
</style>
    {# Filters Section #}
        <div class="filter-bar" style=" padding: 15px 20px; border-radius: 8px; margin-bottom: 20px;">
              <div class="row g-2 align-items-center">
                <div class="col-md-2 col-sm-6">
                  <input type="text" id="filter_po_number" value="{{ filter_po_number }}" placeholder="PO Number"
                         class="form-control"
                         style="background: #0f172a; border: 1px solid #334155; color: #fff!important; padding: 8px 10px;" >
                </div>
                <div class="col-md-2 col-sm-6">
                  <input type="text" id="filter_supplier" value="{{ filter_supplier }}" placeholder="Supplier"
                         class="form-control"
                         style="background: #0f172a; border: 1px solid #334155; color: #fff!important; padding: 8px 10px;">
                </div>
                <div class="col-md-2 col-sm-6">
                  <input type="text" id="filter_product" value="{{ filter_product }}" placeholder="Product"
                         class="form-control"
                         style="background: #0f172a; border: 1px solid #334155; color: #fff!important; padding: 8px 10px;">
                </div>
                <div class="col-md-2 col-sm-6">
                  <input type="date" id="filter_date_from" value="{{ filter_date_from }}" placeholder="From Date"
                         class="form-control"
                         style="background: #0f172a; border: 1px solid #334155; color: #fff; padding: 8px 10px;">
                </div>
                <div class="col-md-2 col-sm-6">
                  <input type="date" id="filter_date_to" value="{{ filter_date_to }}" placeholder="To Date"
                         class="form-control"
                         style="background: #0f172a; border: 1px solid #334155; color: #fff; padding: 8px 10px;">
                </div>
                <div class="col-md-2 col-sm-12 d-flex gap-2">
                  <button type="button" id="button-filter" class="btn btn-primary flex-fill"
                          style="background: #3b82f6; border: none; padding: 8px 10px; white-space: nowrap;">
                    <i class="fa fa-search"></i> Search
                  </button>
                  <button type="button" id="button-clear" class="btn btn-danger flex-fill"
                          style="background: #ef4444; border: none; padding: 8px 10px; white-space: nowrap;">
                    <i class="fa fa-eraser"></i> Clear
                  </button>
                  <button type="button" class="btn btn-success flex-fill" onclick="exportData()"
                          style="background: #10b981; border: none; padding: 8px 10px; white-space: nowrap;">
                    <i class="fa fa-download"></i> Export
                  </button>
                </div>
              </div>
            </div>
            
        {# Main Table #}
                <div class="table-container" style="background: #000000; overflow: hidden; padding: 20px;">
      <div class="table-responsive">
        <table class="table table-dark table-hover m-0" style="color: #fff; border-collapse: separate; border-spacing: 0;">
          <thead style="background: #000000;">
            <tr>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">PO Number</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">Supplier</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">Product</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">Received Date</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">Received Qty</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">Used Qty</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">Balance Qty</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff;">Updated</th>
              <th style="padding: 15px; font-weight: 600; border: 1px solid #ffffff; text-align: center;">Actions</th>
            </tr>
          </thead>
          <tbody>
            {% if purchase_orders %}
              {% for po in purchase_orders %}
                <tr style="background: #000000;">
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <div style="font-weight: 600;">{{ po.po_number }}</div>
                    <small style="color: #94a3b8; font-weight: 600;">{{ po.purchase_order_product_id }}</small>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <div style="font-weight: 600;">{{ po.supplier_name }}</div>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <div style="font-weight: 600;">{{ po.product_name }}</div>
                    <small style="color: #94a3b8;">{{ po.product_model }}</small>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <small style="color: #94a3b8;">{{ po.received_date }}</small>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <div style="font-weight: 600;">{{ po.received_qty }}</div>
                    <small style="font-weight: 600; color: #10b981;">₹{{ po.received_total_price }}</small>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <div style="font-weight: 600;">{{ po.used_qty }}</div>
                    <small style="font-weight: 600; color: #ef4444;">₹{{ po.used_qty_price }}</small>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <div style="font-weight: 700; font-size: 16px; color: {% if po.balance_qty == '0.00' %}#6b7280{% elseif po.balance_qty < 10 %}#f59e0b{% else %}#10b981{% endif %};">
                      {{ po.balance_qty }}
                    </div>
                    <small style="font-weight: 700; color: #3b82f6;">₹{{ po.balance_qty_price }}</small>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff;">
                    <small style="color: #94a3b8;">{{ po.updated_time }}</small>
                  </td>
                  <td style="padding: 15px; border: 1px solid #ffffff; text-align: center;">
                    <div class="btn-group" style="gap: 5px; display: inline-flex;">
                      <button type="button" class="btn btn-sm" onclick="viewBatchHistory({{ po.batchid }})" style="background: #3b82f6; border: none; padding: 8px 12px; border-radius: 5px; color: #fff;" data-bs-toggle="tooltip" title="View History">
                        <i class="fa fa-eye"></i>
                      </button>
                      {% if po.can_edit %}
                        <a href="{{ po.edit }}" class="btn btn-sm" style="background: #10b981; border: none; padding: 8px 12px; border-radius: 5px; color: #fff; text-decoration: none;" data-bs-toggle="tooltip" title="Use Stock">
                          <i class="fa fa-edit"></i>
                        </a>
                      {% else %}
                        <span class="btn btn-sm" style="background: #6b7280; border: none; padding: 8px 12px; border-radius: 5px; color: #fff; cursor: not-allowed;" data-bs-toggle="tooltip" title="Stock Completed">
                          <i class="fa fa-ban"></i>
                        </span>
                      {% endif %}
                    </div>
                  </td>
                </tr>
              {% endfor %}
            {% else %}
              <tr>
                <td colspan="9" style="padding: 40px; text-align: center; color: #64748b; border: 1px solid #ffffff;">
                  <i class="fa fa-inbox fa-3x" style="margin-bottom: 15px;"></i>
                  <p>No stock records found</p>
                </td>
              </tr>
            {% endif %}
          </tbody>
        </table>
      </div>
    </div>
      
      {# Pagination #}
      <div style="background: #0f172a; padding: 15px 20px; border-top: 1px solid #334155;">
        <div class="row align-items-center">
          <div class="col-sm-6">
            <div style="color: #94a3b8;">{{ results }}</div>
          </div>
          <div class="col-sm-6 text-end">
            {{ pagination }}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{# History Modal #}
<div class="modal fade" id="modal-batch-history" tabindex="-1">
  <div class="modal-dialog modal-xl">
    <div class="modal-content" style="background: #1e293b; border: 1px solid #334155;">
      <div class="modal-header" style="border-bottom: 1px solid #334155; background: #0f172a;">
        <h5 class="modal-title" style="color: #fff;"><i class="fa fa-history"></i> Stock History</h5>
        <div  style="padding-left: 791px;">
          <button type="button" class="btn btn-sm" onclick="exportBatchHistory()" style="background: #10b981; color: #fff; border: none; padding: 8px 16px; border-radius: 5px; margin-right: 10px;">
            <i class="fa fa-download"></i> Export CSV
          </button>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
        </div>
      </div>
      <div class="modal-body" id="batch-history-content" style="background: #1e293b; color: #fff; max-height: 600px; overflow-y: auto;">
        <div class="text-center p-5">
          <div class="spinner-border" role="status" style="color: #3b82f6;">
            <span class="visually-hidden">Loading...</span>
          </div>
        </div>
      </div>
      <div class="modal-footer" style="border-top: 1px solid #334155; background: #0f172a;">
        <button type="button" class="btn" data-bs-dismiss="modal" style="background: #6b7280; color: #fff; border: none;">Close</button>
      </div>
    </div>
  </div>
</div>

<style>
.table-dark tbody tr:hover {
  background: #334155 !important;
  cursor: pointer;
}

.btn:hover {
  opacity: 0.9;
  transform: translateY(-1px);
  transition: all 0.2s;
}

.form-control:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: #0f172a;
}

::-webkit-scrollbar-thumb {
  background: #475569;
  border-radius: 5px;
}

::-webkit-scrollbar-thumb:hover {
  background: #64748b;
}

.pagination {
  margin: 0;
}

.pagination .page-link {
  background: #334155;
  border: 1px solid #475569;
  color: #fff;
  margin: 0 2px;
  border-radius: 5px;
}

.pagination .page-link:hover {
  background: #475569;
  color: #fff;
}

.pagination .page-item.active .page-link {
  background: #3b82f6;
  border-color: #3b82f6;
}

input[type="date"] {
  color-scheme: dark;
}

input[type="date"]::-webkit-calendar-picker-indicator {
  filter: invert(1);
}
</style>

<script type="text/javascript">
// Global variables to store current batch history data
var currentBatchHistory = null;
var currentBatchId = null;

$('#button-filter').on('click', function() {
  var url = 'index.php?route=extension/stockregister&user_token={{ user_token }}';
  
  var filter_po_number = $('#filter_po_number').val();
  if (filter_po_number) {
    url += '&filter_po_number=' + encodeURIComponent(filter_po_number);
  }
  
  var filter_supplier = $('#filter_supplier').val();
  if (filter_supplier) {
    url += '&filter_supplier=' + encodeURIComponent(filter_supplier);
  }
  
  var filter_product = $('#filter_product').val();
  if (filter_product) {
    url += '&filter_product=' + encodeURIComponent(filter_product);
  }
  
  var filter_date_from = $('#filter_date_from').val();
  if (filter_date_from) {
    url += '&filter_date_from=' + encodeURIComponent(filter_date_from);
  }
  
  var filter_date_to = $('#filter_date_to').val();
  if (filter_date_to) {
    url += '&filter_date_to=' + encodeURIComponent(filter_date_to);
  }
  
  location = url;
});

$('#filter_po_number, #filter_supplier, #filter_product, #filter_date_from, #filter_date_to').on('keydown', function(e) {
  if (e.keyCode == 13) {
    $('#button-filter').trigger('click');
  }
});

function exportData() {
  var url = 'index.php?route=extension/stockregister.export&user_token={{ user_token }}';
  
  var filter_po_number = $('#filter_po_number').val();
  if (filter_po_number) {
    url += '&filter_po_number=' + encodeURIComponent(filter_po_number);
  }
  
  var filter_supplier = $('#filter_supplier').val();
  if (filter_supplier) {
    url += '&filter_supplier=' + encodeURIComponent(filter_supplier);
  }
  
  var filter_product = $('#filter_product').val();
  if (filter_product) {
    url += '&filter_product=' + encodeURIComponent(filter_product);
  }
  
  var filter_date_from = $('#filter_date_from').val();
  if (filter_date_from) {
    url += '&filter_date_from=' + encodeURIComponent(filter_date_from);
  }
  
  var filter_date_to = $('#filter_date_to').val();
  if (filter_date_to) {
    url += '&filter_date_to=' + encodeURIComponent(filter_date_to);
  }
  
  window.open(url, '_blank');
}

function exportBatchHistory() {
  if (!currentBatchHistory || !currentBatchHistory.history) {
    alert('No history data available to export');
    return;
  }
  
  // Prepare CSV content
  var csv = 'Date Added,Transaction Type,Product Line ID,Used Amount,Balance,Store,Description\n';
  
  // Reverse the array to show in descending order (newest first)
  var reversedHistory = currentBatchHistory.history.slice().reverse();
  
  for (var i = 0; i < reversedHistory.length; i++) {
    var item = reversedHistory[i];
    var row = [
      item.date_added || 'N/A',
      item.transaction_type || 'N/A',
      item.purchase_order_product_id || 'N/A',
      item.amount || '0.00',
      item.balance || '0.00',
      item.store_name || 'N/A',
      '"' + (item.description || 'N/A').replace(/"/g, '""') + '"'
    ];
    csv += row.join(',') + '\n';
  }
  
  // Add summary at the end
  csv += '\n';
  csv += 'Summary\n';
  csv += 'Total Received,' + (currentBatchHistory.current_stock || '0.00') + '\n';
  csv += 'Total Used,' + (currentBatchHistory.used_stock || '0.00') + '\n';
  csv += 'Current Balance,' + (currentBatchHistory.balance_stock || '0.00') + '\n';
  
  // Create download link
  var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  var link = document.createElement('a');
  var url = URL.createObjectURL(blob);
  
  link.setAttribute('href', url);
  link.setAttribute('download', 'batch_history_' + currentBatchId + '_' + new Date().getTime() + '.csv');
  link.style.visibility = 'hidden';
  
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}

function viewBatchHistory(batchid) {
  currentBatchId = batchid;
  
  $.ajax({
    url: 'index.php?route=extension/stockregister.history&user_token={{ user_token }}&batchid=' + batchid,
    type: 'get',
    dataType: 'json',
    beforeSend: function() {
      $('#batch-history-content').html('<div class="text-center p-5"><div class="spinner-border" role="status" style="color: #3b82f6;"><span class="visually-hidden">Loading...</span></div></div>');
      var myModal = new bootstrap.Modal(document.getElementById('modal-batch-history'));
      myModal.show();
    },
    success: function(json) {
      currentBatchHistory = json;
      
      if (json['error']) {
        $('#batch-history-content').html('<div class="alert alert-danger">' + json['error'] + '</div>');
      } else {
        var html = '';
        
        // Current Stock Status Header
        html += '<div style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border-radius: 10px; padding: 25px; margin-bottom: 25px; color: white;">';
        html += '<h4 style="margin: 0 0 20px 0;"><i class="fa fa-cube"></i> Current Stock Status</h4>';
        html += '<div class="row text-center">';
        html += '<div class="col-md-4"><div style="background: rgba(255,255,255,0.2); padding: 20px; border-radius: 8px;"><div style="font-size: 14px; margin-bottom: 5px;">Total Received</div><div style="font-size: 32px; font-weight: 700;">' + json['current_stock'] + '</div></div></div>';
        html += '<div class="col-md-4"><div style="background: rgba(255,255,255,0.2); padding: 20px; border-radius: 8px;"><div style="font-size: 14px; margin-bottom: 5px;">Total Used</div><div style="font-size: 32px; font-weight: 700;">' + json['used_stock'] + '</div></div></div>';
        html += '<div class="col-md-4"><div style="background: rgba(255,255,255,0.2); padding: 20px; border-radius: 8px;"><div style="font-size: 14px; margin-bottom: 5px;">Current Balance</div><div style="font-size: 32px; font-weight: 700;">' + json['balance_stock'] + '</div></div></div>';
        html += '</div></div>';
        
        // Transaction History Table
        if (json['history'] && json['history'].length > 0) {
          html += '<h5 style="color: #fff; margin: 25px 0 15px 0;"><i class="fa fa-clock-o"></i> Stock Transaction History</h5>';
          
          html += '<div class="table-responsive">';
          html += '<table class="table m-0" style="color: #fff;">';
          html += '<thead style="background: #0f172a;">';
          html += '<tr>';
          html += '<th style="padding: 12px; border-bottom: 2px solid #334155;">Date Added</th>';
          html += '<th style="padding: 12px; border-bottom: 2px solid #334155;">Transaction Type</th>';
          html += '<th style="padding: 12px; border-bottom: 2px solid #334155; text-align: right;">Used</th>';
          html += '<th style="padding: 12px; border-bottom: 2px solid #334155; text-align: right;">Balance</th>';
          html += '<th style="padding: 12px; border-bottom: 2px solid #334155;">Store</th>';
          html += '<th style="padding: 12px; border-bottom: 2px solid #334155;">Description</th>';
          html += '</tr>';
          html += '</thead>';
          html += '<tbody>';
          
          // Reverse the array to show in descending order (newest first)
          var reversedHistory = json['history'].slice().reverse();
          
          for (var i = 0; i < reversedHistory.length; i++) {
            var item = reversedHistory[i];
            var bgColor = (i % 2 == 0) ? '#1e293b' : '#0f172a';
            
            html += '<tr style="background: ' + bgColor + '; border-bottom: 1px solid #334155;">';
            
            // Date Added
            html += '<td style="padding: 12px;">';
            html += '<span style="color: #94a3b8;">' + (item.date_added || 'N/A') + '</span>';
            html += '</td>';
            
            // Transaction Type
            html += '<td style="padding: 12px;">';
            html += '<span style="color: #94a3b8;">' + (item.transaction_type || 'N/A') + '</span>';
            html += '</td>';
            
            // Amount (Used)
            html += '<td style="padding: 12px; text-align: right;">';
            html += '<span style="color: #fff; font-weight: 600;">' + (item.amount || '0.00') + '</span>';
            html += '</td>';
            
            // Balance
            html += '<td style="padding: 12px; text-align: right;">';
            html += '<span style="color: #3b82f6; font-weight: 700; font-size: 15px;">' + (item.balance || '0.00') + '</span>';
            html += '</td>';
            
            // Store Name
            html += '<td style="padding: 12px;">';
            html += '<span style="color: #10b981; font-weight: 600;">' + (item.store_name || 'N/A') + '</span>';
            html += '</td>';
            
            // Description
            html += '<td style="padding: 12px;">';
            html += '<span style="color: #fff;">' + (item.description || 'N/A') + '</span>';
            html += '</td>';
            
            html += '</tr>';
          }
          
          html += '</tbody>';
          html += '</table>';
          html += '</div>';
        } else {
          html += '<div class="text-center p-5"><i class="fa fa-inbox fa-3x" style="color: #475569; margin-bottom: 20px;"></i><p style="color: #94a3b8;">No transaction history found</p></div>';
        }
        
        $('#batch-history-content').html(html);
      }
    },
    error: function(xhr, ajaxOptions, thrownError) {
      $('#batch-history-content').html('<div class="alert alert-danger">Error loading history: ' + thrownError + '</div>');
    }
  });
}

$(document).ready(function() {
  $('[data-bs-toggle="tooltip"]').tooltip();
});
$('#button-clear').on('click', function() {
  $('#filter_po_number').val('');
  $('#filter_supplier').val('');
  $('#filter_product').val('');
  $('#filter_date_from').val('');
  $('#filter_date_to').val('');
});
</script>

{{ footer }}