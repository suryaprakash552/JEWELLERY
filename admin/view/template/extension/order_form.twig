                    totalHtml += '<td colspan="4" class="text-end" style="background-color: unset; border: none !important; padding: 8px;"><b>' + t.title + ':</b></td>';
                    totalHtml += '<td class="text-end" width="20%" style="background-color: unset; border: none !important; padding: 8px;"><strong>' + t.text + '</strong></td>';
                    totalHtml += '</tr>';
                }
            }
            $('#total').html(totalHtml);
            
            // Reinitialize image popup
            if ($.fn.magnificPopup) {
                $('.imagepopup').magnificPopup({
                    type: 'image',
                    delegate: 'a',
                    gallery: {
                        enabled: true
                    }
                });
            }
            
            console.log('Products refreshed successfully');
            
            // Update totals after products are loaded
            setTimeout(function() {
                totals();
            }, 200);
            
            console.log('Products refreshed successfully');
        },
        error: function(xhr, ajaxOptions, thrownError) {
            console.error('Refresh error:', thrownError);
            $('#cart').html('<tr><td colspan="16" class="text-center text-danger">Error loading products: ' + thrownError + '</td></tr>');
        }
    });
}

