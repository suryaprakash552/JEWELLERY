{{ header }}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-datetimepicker/2.5.20/jquery.datetimepicker.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-datetimepicker/2.5.20/jquery.datetimepicker.full.min.js"></script>

    <script src="view/javascript/jquery/me_magnific/jquery.magnific-popup.min.js"></script>
  <link href="view/javascript/jquery/me_magnific/magnific-popup.css" rel="stylesheet">
  <!-- jQuery UI CSS -->
<link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

<!-- jQuery UI JS -->
<script src="https://code.jquery.com/ui/1.13.2/jquery-ui.min.js"></script>


{{ column_left }}

<div id="content">
  <div class="page-header">
    <div class="container-fluid d-flex justify-content-between align-items-center">
      <h1>{{ heading_title }}</h1>
      <div class="d-flex gap-3 flex-wrap align-items-end">
        <div class="d-flex align-items-center">
          <label class="form-label mb-0 me-2 required" style="width: 56px; " for="input-po_number">{{ column_po_number }}</label>
          <input type="text" name="po_number" value="{{ po_number }}" placeholder="{{ column_po_number }}" id="input-po_number" style="height: 33px;width: 96px;" class="form-control" readonly>
        </div>

        <div class="d-flex align-items-center">
          <label class="form-label mb-0 me-2" for="input-date_added">{{ entry_date_added }}</label>
          <input type="text" name="date_added" value="{{ date_added }}" placeholder="{{ entry_date_added }}" id="input-date_added" style="height: 33px;width: 96px;" class="form-control datepicker">
        </div>

        <div class="d-flex align-items-center">
          <label class="form-label mb-0 me-2" style="width: 98px;" for="input-delivery_date">{{ entry_delivery_date }}</label>
          <input type="text" name="delivery_date" value="{{ delivery_date }}" placeholder="{{ entry_delivery_date }}" id="input-delivery_date" style="height: 33px; width: 110px;" class="form-control datepicker">
        </div>

        {% if order_id %}
        <div class="mb-0 d-flex gap-2">
          <a href="{{ export }}"  style="height: 33px;" class="btn btn-warning mt-4">{{ button_export }}</a>
          <a href="{{ printorder }}"  style="height: 33px; width: 69px;" class="btn btn-success mt-4">{{ button_print }}</a>
        </div>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="container-fluid">
    <form class="needs-validation" novalidate>
      <div class="row g-3">
        <!-- Buyer Panel -->
        <div class="col-md-6">
          <div class="card mb-3">
            <div class="card-header">{{ text_buyer }}</div>
            <div class="card-body">
              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_store }}</label>
                <div class="col-sm-8">
                  <select name="buyer_id" id="input-contact" class="form-select">
                    {% for store in stores %}
                      <option value="{{ store.store_id }}" {% if store.store_id == buyer_id %}selected{% endif %}>{{ store.name }}</option>
                    {% endfor %}
                  </select>
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_contact }}</label>
                <div class="col-sm-8">
                  <input type="text" name="buyer_contact" value="{{ order_id ? buyer_contact : contact_name }}" placeholder="{{ entry_company }}" id="input-company" class="form-control" />
                  <input type="hidden" name="buyer_company" value="{{ buyer_company ? buyer_company : store_name }}" />
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_address }}</label>
                <div class="col-sm-8">
                  <textarea id="input-address" class="form-control" placeholder="{{ entry_address }}" rows="4" name="buyer_address">{{ order_id ? buyer_address : store_address }}</textarea>
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_zip_code }}</label>
                <div class="col-sm-8">
                  <input type="text" name="buyer_zip_code" value="{{ buyer_zip_code ? buyer_zip_code : store_geocode }}" placeholder="{{ entry_zip_code }}" class="form-control" />
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_telephone }}</label>
                <div class="col-sm-8">
                  <input type="text" name="buyer_tel" value="{{ order_id ? buyer_tel : store_telephone }}" placeholder="{{ entry_telephone }}" class="form-control" />
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_email }}</label>
                <div class="col-sm-8">
                  <input type="text" name="buyer_email" value="{{ order_id ? buyer_email : store_email }}" placeholder="{{ entry_email }}" class="form-control" />
                  <input type="hidden" name="buyer_contact_tel" value="">
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Supplier Panel -->
        <div class="col-md-6">
          <div class="card mb-3">
            <div class="card-header">{{ text_supplier }}</div>
            <div class="card-body">
              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_contact }}</label>
                <div class="col-sm-8 position-relative">
                  <input type="text" name="supplier_contact" value="{{ supplier_contact }}" placeholder="{{ entry_contact }}" class="form-control" data-oc-target="autocomplete-supplier_contact" autocomplete="off" />
                  <ul id="autocomplete-supplier_contact" class="dropdown-menu"></ul>
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_company }}</label>
                <div class="col-sm-8">
                  <input type="text" name="supplier_company" value="{{ supplier_company }}" placeholder="{{ entry_company }}" class="form-control" />
                  <input type="hidden" name="supplier_id" value="{{ supplier_id }}" />
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_address }}</label>
                <div class="col-sm-8">
                  <textarea name="supplier_address" placeholder="{{ entry_address }}" class="form-control" rows="4">{{ supplier_address }}</textarea>
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_zip_code }}</label>
                <div class="col-sm-8">
                  <input type="text" name="supplier_zip_code" value="{{ supplier_zip_code }}" placeholder="{{ entry_zip_code }}" class="form-control" />
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_telephone }}</label>
                <div class="col-sm-8">
                  <input type="text" name="supplier_tel" value="{{ supplier_tel }}" placeholder="{{ entry_telephone }}" class="form-control" />
                </div>
              </div>

              <div class="mb-3 row">
                <label class="col-sm-4 col-form-label">{{ entry_email }}</label>
                <div class="col-sm-8">
                  <input type="text" name="supplier_email" value="{{ supplier_email }}" placeholder="{{ entry_email }}" class="form-control" />
                  <input type="hidden" name="supplier_contact_tel" value="">
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

     <!-- Shipping & Payment Section -->
        <div class="row g-3 mb-3">
          <!-- Shipping Method -->
          <div class="col-md-6">
            <label class="form-label">{{ entry_shipping_method }}</label>
            <select name="shipping_method" class="form-select">
              <option value="">{{ text_select }}</option>
              <option value="free_shipping" {% if shipping_method == 'free_shipping' %}selected{% endif %}>Free Shipping</option>
              <option value="flat_shipping" {% if shipping_method == 'flat_shipping' %}selected{% endif %}>Flat Shipping</option>
              {% for shippingmethod in shipping_methods %}
              <option value="{{ shippingmethod['code'] }}" {% if shippingmethod['code'] == shipping_method %}selected{% endif %}>{{ shippingmethod['title'] }}</option>
              {% endfor %}
            </select>
          </div>
        
          <!-- Shipping Term -->
          <div class="col-md-6">
            <label class="form-label">{{ entry_shipping_term }}</label>
            <input type="text" name="shipping_term" value="{{ shipping_term }}" class="form-control" placeholder="Enter shipping term">
          </div>
        
          <!-- Payment Method -->
          <div class="col-md-6">
            <label class="form-label">{{ entry_payment_method }}</label>
            <select name="payment_method" class="form-select">
              <option value="">{{ text_select }}</option>
              <option value="cod" {% if payment_method == 'cod' %}selected{% endif %}>COD (Cash on Delivery)</option>
              <option value="card" {% if payment_method == 'card' %}selected{% endif %}>Card Payment</option>
              {% for paymentmethod in payment_methods %}
              <option value="{{ paymentmethod['code'] }}" {% if paymentmethod['code'] == payment_method %}selected{% endif %}>{{ paymentmethod['title'] }}</option>
              {% endfor %}
            </select>
          </div>
        
          <!-- Order Status -->
          <div class="col-md-6">
            <label class="form-label">{{ entry_status }}</label>
            <select name="status" class="form-select">
              <option value="">{{ text_select }}</option>
              {% if order_statuses %}
                {% for order_status in order_statuses %}
                <option value="{{ order_status['name'] }}" {% if order_status['name'] == status %}selected{% endif %}>{{ order_status['name'] }}</option>
                {% endfor %}
              {% endif %}
            </select>
          </div>
        </div>

      <!-- Product Table -->
      <div class="card mb-3">
        <div class="card-header">{{ text_product }}</div>
        <div class="card-body table-responsive">
          <table class="table table-bordered table-hover table-striped">
            <thead class="table-light">
              <tr>
                {% set colspan = 1 %}
                {% for key,column in purchase_order_column %}
                    {% if column['status'] and key != 'option' %}
                  <th class="text-center">{{ column['name'] }}</th>
                  {% set colspan = colspan + 1 %}
                  {% endif %}
                {% endfor %}
                <th>{{ column_action }}</th>
              </tr>
            </thead>
            <tbody id="cart">
              {% if order_products %}
                {% set product_row = 0 %}
                {% for order_product in order_products %}
                  <tr>
                      <tr>
                          {% for key, column in purchase_order_column %}
                            {% if column['status'] %}
                              {% if key == 'serial_no' %}
                                <td class="text-center">{{ loop.index }}</td>
                        
                              {% elseif key == 'sku' %}
                                <td>{{ order_product.sku ?? '' }}</td>
                        
                              {% elseif key == 'description' %}
                                <td>{{ order_product.name ?? '' }}</td>
                        
                              {% elseif key == 'image' %}
                              <td class="text-center">
                                {% if order_product['image'] %}
                                  <img src="{{ order_product['image'] }}" alt="{{ order_product['name'] }}" style="width:50px; height:50px; object-fit:cover; border-radius:5px;">
                                {% else %}
                                  <span style="color:#888;">No Image</span>
                                {% endif %}
                              </td>

                        
                              {% elseif key == 'model' %}
                                <td>{{ order_product.model ?? '' }}</td>
                        
                              {#{% elseif key == 'option' %}#}
                              {#  <td>{{ order_product.option ?? '' }}</td>#}
                        
                              {% elseif key == 'weight' %}
                                <td>{{ order_product.weight ?? '' }}</td>
                        
                              {% elseif key == 'dimension' %}
                                <td>{{ order_product.dimension ?? '' }}</td>
                                
                              {% elseif key == 'stock' %}
                                <td>{{ order_product.stock ?? '' }}</td>
                                
                              {% elseif key == 'sale_price' %}
                                <td>{{ order_product.sale_price ?? '' }}</td> 
                                
                              {% elseif key == 'discount' %}
                                <td>{{ order_product.discount ?? '' }}</td> 
                                
                              {% elseif key == 'price' %}
                                <td>{{ order_product.price ?? '' }}</td> 
                                
                              {% elseif key == 'quantity' %}
                                <td>{{ order_product.quantity ?? '' }}</td> 
                                
                              {% elseif key == 'total' %}
                                <td>{{ order_product.total ?? '' }}</td> 
                        
                              {#{% elseif key in ['stock', 'price', 'discount','saleprice', 'quantity', 'total'] %}#}
                              {#  <td class="text-end">{{ order_product[key] ?? '' }}</td>#}
                        
                              {#{% elseif key == 'size' %}
                                <td>{{ order_product.size ?? '' }}</td>#}
                        
                              {% else %}
                                <td>{{ order_product[key] ?? '' }}</td>
                        
                              {% endif %}
                            {% endif %}
                          {% endfor %}
                        
                          <!-- Action Button -->
                          <td class="text-center">
                            {% if order_product.unbelong %}
                              <button type="button" class="btn btn-danger btn-sm" onclick="$(this).closest('tr').remove();">
                                <i class="fa fa-minus-circle"></i>
                              </button>
                            {% endif %}
                          </td>
                        </tr>
                          {% set product_row = product_row + 1 %}
                        {% endfor %}
                      {% else %}
                        <tr>
                          <td class="text-center" colspan="{{ colspan }}">{{ text_no_results }}</td>
                        </tr>
                      {% endif %}
                    </tbody>
                  </table>

         <div class="mt-3 d-flex justify-content-end gap-2">
            <button type="button" class="btn btn-success btn-refresh">
                <i class="fa fa-refresh"></i> {{ button_refresh }}
            </button>
        
            <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#bulkaddproduct">
                <i class="fa fa-plus-circle"></i> {{ button_bulk_product_add }}
            </button>
        
            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#fieldmanager">
                <i class="fa fa-plus-circle"></i> {{ button_product_add }}
            </button>
        </div>

        </div>
      </div>

      <!-- Order Totals Panel -->
        <div class="card mb-3">
            <div class="card-header">{{ entry_custom_fee_dis }}</div>
            <div class="card-body">
                <!-- Custom Totals Table -->
                <div class="table-responsive {% if not me_purchase_order_setting_customfeedisstatus %}d-none{% endif %}">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>{{ entry_title }}</th>
                                <th>{{ entry_type }}</th>
                                <th>{{ entry_dtype }}</th>
                                <th>{{ entry_discount }}</th>
                                <th class="text-end">{{ entry_action }}</th>
                            </tr>
                        </thead>
                        <tbody id="custom-totals">
                            {% set po_custom_total_row = 0 %}
                            {% for po_custom_total in po_custom_totals %}
                            <tr id="custom-total-{{ po_custom_total_row }}">
                                <td><input type="text" name="po_custom_total[{{ po_custom_total_row }}][title]" value="{{ po_custom_total['name'] ? po_custom_total['name'] : '' }}" class="form-control" placeholder="{{ text_title }}" /></td>
                                <td>
                                    <select name="po_custom_total[{{ po_custom_total_row }}][type]" class="form-select">
                                        <option value="1" {% if po_custom_total['type'] %}selected{% endif %}>{{ text_discount }}</option>
                                        <option value="0" {% if not po_custom_total['type'] %}selected{% endif %}>{{ text_fee }}</option>
                                    </select>
                                </td>
                                <td>
                                    <select name="po_custom_total[{{ po_custom_total_row }}][dtype]" class="form-select">
                                        <option value="P" {% if po_custom_total['dtype'] == 'P' %}selected{% endif %}>{{ text_percent }}</option>
                                        <option value="F" {% if po_custom_total['dtype'] == 'F' %}selected{% endif %}>{{ text_total_amount }}</option>
                                    </select>
                                </td>
                                <td><input type="text" name="po_custom_total[{{ po_custom_total_row }}][amt]" value="{{ po_custom_total['discount'] ? po_custom_total['discount'] : '' }}" class="form-control" placeholder="{{ text_amount }}" /></td>
                                <td class="text-end">
                                    <button type="button" class="btn btn-primary btn-sm" onclick="loadcustomtotal();"><i class="fa fa-plus-circle"></i></button>
                                    <button type="button" class="btn btn-danger btn-sm" onclick="removecustomototal('{{ po_custom_total_row }}')"><i class="fa fa-minus-circle"></i></button>
                                </td>
                            </tr>
                            {% set po_custom_total_row = po_custom_total_row + 1 %}
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="5" class="text-end">
                                    <button type="button" class="btn btn-primary btn-sm" onclick="addcustomtotalmore();"><i class="fa fa-plus-circle"></i></button>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
        
                <!-- Tax and Balance Section -->
                <div class="row g-3 mb-3 {% if not me_purchase_order_setting_tax and not me_purchase_order_setting_balance %}d-none{% endif %}">
                    <!-- Tax -->
                    {% if me_purchase_order_setting_tax %}
                    <div class="col-md-6">
                        <label class="form-label">{{ entry_tax }}</label>
                        <div class="input-group">
                            <input type="text" name="tax" value="{{ tax }}" placeholder="{{ entry_tax }}" class="form-control" />
                            <button type="button" id="button-tax" class="btn btn-primary">{{ button_apply }}</button>
                        </div>
                    </div>
                    {% endif %}
        
                    <!-- Balance -->
                    {% if me_purchase_order_setting_balance %}
                    <div class="col-md-6">
                        <label class="form-label">{{ entry_balance }}</label>
                        <div class="input-group">
                            <input type="text" name="balance" value="{{ balance }}" placeholder="{{ entry_balance }}" class="form-control" />
                            <button type="button" id="button-balance" class="btn btn-primary">{{ button_apply }}</button>
                        </div>
                    </div>
                    {% endif %}
                </div>
        
                <!-- Order Summary -->
                <div class="row">
                    <div class="col-md-8"></div>
                    <div class="col-md-4">
                        <table class="table table-borderless">
                            <tbody id="total">
                                <!-- Totals will be dynamically updated here -->
                            </tbody>
                        </table>
                    </div>
                </div>
        
                <!-- Notify Supplier Section (Optional) -->
                {#<div class="row mt-3 d-none">#}
                {#    <div class="col-12">#}
                {#        <div class="form-check">#}
                {#            <input class="form-check-input" type="checkbox" name="notify_supplier" value="1" id="input-notify-supplier">#}
                {#            <label class="form-check-label" for="input-notify-supplier">#}
                {#                {{ entry_notify_supplier }}#}
                {#                <span class="text-muted"><i class="fa fa-question-circle" data-bs-toggle="tooltip" title="{{ help_notify_supplier }}"></i></span>#}
                {#            </label>#}
                {#        </div>#}
                {#    </div>#}
                {#</div>#}
            </div>
        </div>
        
        <!-- Comments Section -->
        {% if me_purchase_order_setting_comment %}
        <div class="card mb-3">
            <div class="card-header">{{ entry_comments }}</div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label">{{ entry_comment }}</label>
                    <textarea name="order_comment" rows="4" placeholder="{{ entry_comment }}" class="form-control"></textarea>
                </div>
                
                {% if order_id %}
                <div class="mb-3">
                    <label class="form-label">{{ button_upload }}</label>
                    <div class="input-group">
                        {#<input type="text" class="form-control" placeholder="Upload attachment" readonly>#}
                        <button type="button" class="btn btn-secondary btn-attachment"><i class="fa fa-upload"></i> {{ button_upload }}</button>
                    </div>
                </div>
        
                <div class="attachments mb-3">
                    <div class="row">
                        {% for attachment in attachments %}
                        <div class="col-sm-2" id="{{ attachment.code }}">
                            <div class="attachment position-relative border rounded p-2">
                                <i class="fa fa-times position-absolute top-0 end-0 text-danger removeattach" rel="{{ attachment.code }}" style="cursor: pointer;"></i>
                                {{ attachment.new_msg|raw }}
                                <input type="hidden" name="attachment[]" value="{{ attachment.code }}">
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                </div>
        
                <button type="button" id="add_comment" class="btn btn-success"><i class="fa fa-plus-circle"></i> {{ button_add_comment }}</button>
        
                <div class="mt-3" id="product_comments">
                    {% if product_comments %}
                    <table class="table table-bordered">
                        {% for product_comment in product_comments %}
                        <tr id="comment{{ product_comment.comment_id }}">
                            <td class="first-td" style="width: 150px;">{{ product_comment.date_added }}</td>
                            <td class="ordercomment">{{ product_comment.comment }}</td>
                            <td class="text-end" style="width: 100px;">
                                <button type="button" class="btn btn-primary btn-sm" onclick="editcomment({{ product_comment.comment_id }});"><i class="fa fa-pencil"></i></button>
                                <button type="button" class="btn btn-danger btn-sm" onclick="deletecomment({{ product_comment.comment_id }});"><i class="fa fa-times"></i></button>
                            </td>
                        </tr>
                        {% endfor %}
                    </table>
                    {% endif %}
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}
        
      <!-- Save Buttons -->
      <div class="text-end mb-3">
        {% if order_id %}
          <button type="button" id="button-save" class="btn btn-primary"><i class="fa fa-check-circle"></i> {{ button_save }}</button>
        {% else %}
          <button type="button" id="button-save1" class="btn btn-primary"><i class="fa fa-check-circle"></i> {{ button_save }}</button>
        {% endif %}
      </div>
    </form>
  </div>
</div>


<!-- Single Product Modal -->
<div class="modal fade" id="fieldmanager" tabindex="-1" aria-labelledby="fieldname" >
  <div class="modal-dialog">
    <div class="modal-content"  style="background-color: black;">
      <div class="modal-header d-flex align-items-center">
        <h5 class="modal-title" id="fieldname">{{ text_product }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form method="post" enctype="multipart/form-data" id="form-order_product">
          <div class="mb-3 row">
            <label for="input-product" class="col-sm-3 col-form-label">{{ entry_product }}</label>
            <div class="col-sm-9">
              <input type="text" name="product" id="input-product" class="form-control" data-oc-target="autocomplete-product" autocomplete="off"/>
                    <ul id="autocomplete-product" class="dropdown-menu"></ul>
              <input type="hidden" name="product_id" value="" />
            </div>
          </div>
          <div class="mb-3 row">
            <label for="input-quantity" class="col-sm-3 col-form-label">{{ entry_quantity }}</label>
            <div class="col-sm-9">
              <input type="text" name="quantity" id="input-quantity" value="1" class="form-control" />
              <input type="hidden" name="stock" id="input-stock" class="form-control" />
            </div>
          </div>
          <div class="mb-3 row d-none">
            <label for="input-comment" class="col-sm-3 col-form-label">{{ entry_comment }}</label>
            <div class="col-sm-9">
              <textarea name="comment" id="input-comment" rows="4" class="form-control" placeholder="{{ entry_comment }}"></textarea>
            </div>
          </div>
          <div id="option"></div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" id="button-product-add" class="btn btn-primary">
          <i class="fa fa-plus-circle"></i> {{ button_product_add }}
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Bulk Product Modal -->
<div class="modal fade" id="bulkaddproduct" tabindex="-1" aria-labelledby="bulkaddproductname" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header d-flex align-items-center">
        <h5 class="modal-title" id="bulkaddproductname">{{ entry_bulk_product_add }}</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <form method="post" enctype="multipart/form-data" id="form-bulk_order_product">
          <div class="row mb-3 g-2">
            <div class="col-sm-3">
