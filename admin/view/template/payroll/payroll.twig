<script type="text/javascript">
    var currentPayrollData = null; // Global variable for payment modal
    
    // Handle view payroll button
   $(document).on('click', '.view-payroll', function () {
    const id = $(this).data('payroll-id');
    $.ajax({
        url: 'index.php?route=payroll/payroll.view&user_token={{ user_token }}',
        type: 'post',
        dataType: 'json',
        data: { id: id },
        success: function (response) {
            const payroll = response['payroll'];

            // Store this payroll globally so payment modal can access it later
            currentPayrollData = payroll;
            
            otherEarnings=0;
            otherDeductions=0;
            
            // Earnings
            const basic = parseFloat(payroll['basic']) || 0;
            const hra = parseFloat(payroll['hra']) || 0;
            const variablePay = parseFloat(payroll['variable_pay']) || 0;
            const fixedAllowance = parseFloat(payroll['fixed_allowance']) || 0;
            const perDayPayment = parseFloat(payroll['net_salary'])/parseInt(payroll['current_month_days']);
            // Deductions
            const pf = parseFloat(payroll['pf']) || 0;
            
            if(parseInt(payroll['over_time']) === 0)
            {
                otherDeductions = perDayPayment * parseFloat(payroll['balance_days']);
            }else
            {
                otherDeductions=0;
            }
        
            if(parseInt(payroll['over_time']) === 1)
            {
                otherEarnings = perDayPayment * parseFloat(payroll['balance_days']);
            }else
            {
                otherEarnings=0;
            }

            // Totals
            const totalEarnings = basic + hra + variablePay + fixedAllowance + otherEarnings;
            const totalDeductions = pf + otherDeductions;
            const totalPay = totalEarnings - otherDeductions;
            const effectiveDays = parseInt(payroll['current_month_days']) - (parseInt(payroll['Total_Weekends']) + parseInt(payroll['total_festivals']));
            
            // Basic Info
            $('#modalId').text(payroll['id']);
            $('#modalEmpId').text(payroll['emp_id']);
            $('#modalMonth').text(payroll['month'] + '/' + payroll['year']);
            $('#modalDaysInMonth').text(payroll['current_month_days']);
            $('#modalPresent').text(payroll['total_attendees']);
            $('#modalLeaves').text(payroll['leaves_applied']);
            $('#modalWeekends').text(payroll['Total_Weekends']);
            $('#modalFestivals').text(payroll['total_festivals']);
            $('#modalTotalDays').text(payroll['total_days']);
            $('#modalPaidLeaves').text(payroll['paid_leaves']);
            $('#modalBalance').text(payroll['balance_days']);
            $('#modalEffectiveDays').text(effectiveDays);
            
            // Update Fields
            $('#modalBasic').text( basic.toFixed(2));
            $('#modalHRA').text(hra.toFixed(2));
            $('#modalVariable').text( variablePay.toFixed(2));
            $('#modalFixed').text( fixedAllowance.toFixed(2));
            $('#modalPF').text( pf.toFixed(2));
            
            $('#modalOtherDeduction').text(otherDeductions.toFixed(2));
            $('#modelOtherEarning').text(otherEarnings.toFixed(2));
            
            $('#modalTotalEarnings').text(totalEarnings.toFixed(2));
            $('#modalTotalDeductions').text(totalDeductions.toFixed(2));
            $('#modalTotalPay').text(totalPay.toFixed(2));
            
            // Show Modal
            $('#payrollModal').modal('show');
        },
        error: function (xhr, ajaxOptions, thrownError) {
            alert(xhr.responseText);
        }
    });
  });

  // Handle delete button click
    $(document).on('click', '.delete-payroll', function(e) {
        e.preventDefault();
    
        const id = $(this).data('payroll-id');
        $('#confirmDeleteBtn').data('payroll-id', id);
        $('#deleteModalBody').text('Are you sure you want to delete payroll record #' + id + '?');
        $('#deleteConfirmModal').modal('show');
    });
    
    // Confirm delete with refresh
    $('#confirmDeleteBtn').on('click', function(e) {
        e.preventDefault();
    
        const id = $(this).data('payroll-id');
        $('#deleteConfirmModal').modal('hide');
        
        // Show loading
        $('#loading-text').text('Deleting payroll...');
        $('#loadingModal').modal('show');
    
        $.ajax({
            url: 'index.php?route=payroll/payroll.delete&user_token={{ user_token }}',
            type: 'POST',
            dataType: 'json',
            data: { id: id },
            success: function(response) {
                $('#loadingModal').modal('hide');
                
                if (response.success) {
                    alert('Payroll record deleted successfully!');
                    // Refresh the filtered data
                    filterEmployees();
                } else {
                    alert(response.error || 'Failed to delete record.');
                }
            },
            error: function(xhr, status, error) {
                $('#loadingModal').modal('hide');
                console.error('Error deleting payroll:', error);
                alert('An unexpected error occurred while deleting.');
            }
        });
    });
      
  // Handle payslip button
$(document).on('click', '.print-payslip', function () 
{
    id=$(this).data('payroll-id');
    
    // Show payslip modal
    $('#payslipModal').modal('show');
    
    // Reset content to loading state
    $('#payslipContent').html(
        '<div class="text-center py-5">' +
        '<div class="spinner-border text-primary" role="status">' +
        '<span class="visually-hidden">Loading...</span>' +
        '</div>' +
        '<p class="mt-2">Loading payslip...</p>' +
        '</div>'
    );
    
    $.ajax({
        url: 'index.php?route=payroll/payroll.payslip&user_token={{ user_token }}',
        type: 'post',
        dataType: 'json',
        data: 'id=' + id,
        contentType: 'application/x-www-form-urlencoded',
        success: function (response) {
            if (response.success) {
                var pdfUrl = response.pdf_url || '';
                var cacheBuster = '?nocache=' + new Date().getTime();
                
                $('#payslipContent').html(
                    '<iframe type="application/pdf" src="' + pdfUrl + cacheBuster + '" style="width:100%; height:100vh; border:none;"></iframe>'
                );
            } else {
                $('#payslipContent').html(
                    '<div class="alert alert-danger">' +
                    '<i class="fa-solid fa-exclamation-triangle"></i> ' +
                    (response.error || 'Failed to load payslip') +
                    '</div>'
                );
            }
        },
        error: function(xhr) {
            $('#payslipContent').html(
                '<div class="alert alert-danger">' +
                '<i class="fa-solid fa-exclamation-triangle"></i> ' +
                'Error loading payslip: ' + xhr.responseText +
                '</div>'
            );
        }
    });
});

// Open Payment Modal from View Modal
$(document).on('click', '#btnOpenPaymentModal', function() {
    if (!currentPayrollData || !currentPayrollData.id) {
        alert('No payroll data available');
        return;
    }
    
    // Populate payment modal
    $('#paymentPayrollId').val(currentPayrollData.id);
