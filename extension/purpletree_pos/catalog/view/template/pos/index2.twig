                <p style="font-size: 16px; color: #555; line-height: 1.6;">This paid service (Rs: 12000/-) is not available at this movement. Please click here to Activate.</p>
                <div class="mt-4 d-flex justify-content-center gap-3">
                  <button class="btn btn-secondary" data-bs-dismiss="modal" style="padding: 10px 25px;" onclick="resetRenewalModal()">Cancel</button>
                  <button class="btn btn-primary" id="startRenewalBtn" style="padding: 10px 25px; background: #C9A24D; border: none;">Activate</button>
                </div>
              </div>
              <div id="renewalOtpStep" style="display: none; text-align: left;">
                <div class="mb-3" style="display: none;">
                  <label class="form-label" style="font-weight: 600; color: #4A5568;">Phone Number</label>
                  <input type="text" id="renewalPhone" class="form-control" value="7362578939" placeholder="Enter 10 digit number" maxlength="10" style="font-size: 16px; padding: 12px; border: 2px solid #E2E8F0; color:black;">
                </div>
                <button class="btn btn-primary w-100 mb-3" id="renewalGenOtpBtn" style="background: #C9A24D; border: none; padding: 12px; font-weight: 600; display: none;">Generate OTP</button>   
                <div id="renewalVerifySection" style="display: none;">
                  <div class="mb-3">
                    <label class="form-label" style="font-weight: 600; color: #4A5568;">Enter OTP</label>
                    <input type="text" id="renewalOtp" class="form-control" placeholder="Enter OTP" style="font-size: 16px; padding: 12px; border: 2px solid #E2E8F0; color: black;">
                  </div>
                  <button class="btn btn-success w-100" id="renewalVerifyBtn" style="padding: 12px; font-weight: 600;">Verify & Proceed</button>
                </div>
              </div>
              <div id="renewalStatusMsg" style="margin-top: 15px; display: none; font-size: 14px;"></div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal fade" id="printDetailsModal" tabindex="-1" aria-labelledby="printDetailsModalLabel" aria-hidden="true" style="z-index: 9999;">
         <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="background:#1a1f2e;color:#fff;border-radius:12px;box-shadow: 0 10px 30px rgba(0,0,0,0.5);">
               <div class="modal-header" style="border-bottom: 1px solid #2a3040;">
                  <h5 class="modal-title" id="printDetailsModalLabel" style="font-weight: 700; color: #C9A24D;">Print Details</h5>
                  <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
               </div>
               <div class="modal-body" style="padding: 24px;">
                  <div class="form-group mb-4">
                     <label class="form-label" style="font-size: 22px; color: #8a93a2; text-transform: uppercase; letter-spacing: 0.5px;">Order ID</label>
                     <input type="text" id="printDetailsOrderId" class="form-control" placeholder="Enter order id" style="background: #0f121a; border: 1px solid #2a3040; color: #fff; height: 48px; font-size: 22px;">
                  </div>
                  <div class="form-group mb-4">
                     <label class="form-label" style="font-size: 22px; color: #8a93a2; text-transform: uppercase; letter-spacing: 0.5px;">Date</label>
                     <input type="text" id="printDetailsDate" class="form-control" placeholder="dd-mm-yyyy" style="background: #0f121a; border: 1px solid #2a3040; color: #fff; height: 48px; font-size: 22px;">

                  </div>
               </div>
               <div class="modal-footer" style="border-top: 1px solid #2a3040; padding: 16px 24px;">
                  <button type="button" class="btn btn-link" data-bs-dismiss="modal" style="color: #8a93a2; text-decoration: none; font-weight: 600;">Cancel</button>
                  <button type="button" class="btn btn-success" id="printDetailsConfirmBtn" onclick="confirmPrintDetailsAndSubmit()" style="background: #C9A24D; border: none; padding: 10px 24px; font-weight: 700; border-radius: 6px; color: white;">Print</button>
               </div>
            </div>
         </div>
      </div>
      <div id="premiumLoader" class="pos-loader-overlay">
          <div class="pos-loader-spinner"></div>
          <div class="pos-loader-text">Loading...</div>
      </div>
      <!-- DQ12 Serial Port Canvas Elements (Hidden) -->
      <div id="dq12Output" style="display:none;">
        <canvas id="overlayCanvas" width="280" height="280"></canvas>
        <canvas id="canvas" width="320" height="480"></canvas>
      </div>
      <script>
          document.addEventListener('DOMContentLoaded', function(){
              const tabApp = document.getElementById('tabApp');
              const tabProducts = document.getElementById('tabProducts');
              if(tabApp) tabApp.addEventListener('click', ()=>switchRightTab('app'));
              if(tabProducts) tabProducts.addEventListener('click', ()=>switchRightTab('products'));
              loadCategoriesRight();
              switchRightTab('app');
              const printDetailsDate = document.getElementById('printDetailsDate');
              if (printDetailsDate) {
                  if (window.jQuery && typeof $(printDetailsDate).datepicker === 'function') {
                      $(printDetailsDate).datepicker({ dateFormat: 'dd-mm-yy' });
                  } else {
                      printDetailsDate.type = 'date';
                  }
              }
          });
function switchRightTab(name){
    const appRight = document.getElementById('appRightContent');
    const catList = document.getElementById('categoryListRight');
    const prodList = document.getElementById('productListRight');
    if(appRight) appRight.style.display = (name==='app' ? 'block' : 'none');
    if(catList) catList.style.display = 'grid';
    if(prodList) prodList.style.display = (name==='products' ? 'grid' : 'none');
    document.getElementById('tabApp').classList.toggle('active', name==='app');
    document.getElementById('tabProducts').classList.toggle('active', name==='products');
}
function loadCategoriesRight(){
    fetch('index.php?route=extension/purpletree_pos/pos/home.getInitialData')
    .then(r=>r.json())
    .then(data=>{
        if(data && data.status==='success' && Array.isArray(data.categories)){
            const list = document.getElementById('categoryListRight');
            if(!list) return;
            list.innerHTML='';
            data.categories.forEach(cat=>{
                const btn = document.createElement('button');
                btn.textContent = cat.name;
                btn.className = 'category-btn';
                btn.addEventListener('click', ()=>showCategoryProductsRight(cat));
                list.appendChild(btn);
            });
        }
    })
    .catch(err=>console.error('category load failed',err));
}
function showCategoryProductsRight(cat){
    switchRightTab('products');
    const list = document.getElementById('productListRight');
    if(!list) return;
    list.innerHTML = '';
    if(Array.isArray(cat.products)){
        cat.products.forEach(p=>{
            const btn = document.createElement('button');
            btn.innerHTML = `
                <div class="product-name">${p.name}</div>
                <div class="product-price">₹ ${p.price}</div>
            `;
            btn.className = 'product-btn';
            btn.addEventListener('click', ()=> {
                const productData = Object.assign({}, p, {
                    pos_quantity: p.pos_quentity || p.pos_quantity || 0
                });
                addProductToCart(productData);
            });
            list.appendChild(btn);
        });
    }
    list.style.display = 'grid';
    list.style.gridTemplateColumns = 'repeat(4, 1fr)';
}
document.addEventListener('keydown', function(event) {
             if (event.ctrlKey && (event.key === 'b' || event.key === 'B')) {
                 event.preventDefault();
                 openQuickAddModal();
             }
         });
      </script>
      
</body>
</html>

